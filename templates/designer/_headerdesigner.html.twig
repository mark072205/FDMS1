{# Designer top navigation partial. Expects an optional `active` variable (e.g. 'dashboard') #}
<header class="header-designer-no-avatar">
    <div class="header-designer-left">
        <a href="{{ path('app_designer_homepage') }}" class="designer-logo-link">
            <img src="{{ asset('img/Logo2.png') }}" alt="Mark & Motion">
        </a>

        <nav class="designer-nav" aria-label="Main navigation">
            <a href="{{ path('app_designer_homepage') }}" class="designer-nav-item {{ active is defined and active == 'home' ? 'active' : '' }}">Design Studio</a>
            <a href="{{ path('app_designer_projects') }}" class="designer-nav-item {{ active is defined and active == 'projects' ? 'active' : '' }}">Projects</a>
            <a href="{{ path('app_designer_messages') }}" class="designer-nav-item {{ active is defined and active == 'messages' ? 'active' : '' }}">Messages</a>
            <a href="{{ path('app_designer_earnings') }}" class="designer-nav-item {{ active is defined and active == 'earnings' ? 'active' : '' }}">Earnings</a>
        </nav>
    </div>

    <div class="header-designer-right">
        <div class="designer-search-box" role="designer-search">
            <svg class="designer-icon search-icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden>
                <path d="M21 21l-4.35-4.35" stroke="#6b7280" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <circle cx="11" cy="11" r="6" stroke="#6b7280" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <input type="search" placeholder="Search projects, clients, designs..." aria-label="Search" id="designerSearchInput">
        </div>

        <button class="designer-icon bell" type="button" aria-label="Notifications">
            {# Use bootstrap icon element so markup is consistent with other icons #}
            <i class="bi bi-bell" aria-hidden="true"></i>
            <span class="dot" aria-hidden></span>
        </button>

        <div class="designer-badge" onclick="toggleDropdown()" title="Account">
            <div class="designer-profile-avatar">
                {% if app.user and app.user.profilePicture %}
                    <img src="{{ asset('uploads/profile_pictures/' ~ app.user.profilePicture) }}" alt="{{ app.user.firstName }} {{ app.user.lastName }}" style="width: 100%; height: 100%; border-radius: 50%; object-fit: cover;">
                {% else %}
                    {% if app.user %}
                        {{ app.user.firstName|first|upper }}{{ app.user.lastName|first|upper }}
                    {% else %}
                        D
                    {% endif %}
                {% endif %}
            </div>
            <div class="designer-dropdown" id="designerDropdown">
                <div class="designer-profile-section">
                    <div class="designer-profile-info">
                        <div class="designer-profile-avatar">
                            {% if app.user and app.user.profilePicture %}
                                <img src="{{ asset('uploads/profile_pictures/' ~ app.user.profilePicture) }}" alt="{{ app.user.firstName }} {{ app.user.lastName }}" style="width: 100%; height: 100%; border-radius: 50%; object-fit: cover;">
                            {% else %}
                                {% if app.user %}
                                    {{ app.user.firstName|first|upper }}{{ app.user.lastName|first|upper }}
                                {% else %}
                                    D
                                {% endif %}
                            {% endif %}
                        </div>
                        <a href="{{ path('app_designer_profile') }}" class="designer-profile-details" style="text-decoration: none; color: inherit;">
                            <h3>{{ app.user ? app.user.firstName ~ ' ' ~ app.user.lastName : 'Designer' }}</h3>
                            <p>Designer</p>
                        </a>
                    </div>
                </div>
                <div class="designer-dropdown-menu">
                    <a href="{{ path('app_designer_profile') }}" class="designer-menu-item">
                        <div class="designer-menu-item-icon"><i class="bi bi-person"></i></div>
                        Profile Settings
                    </a>
                    <a href="#" class="designer-menu-item">
                        <div class="designer-menu-item-icon"><i class="bi bi-briefcase"></i></div>
                        Portfolio
                    </a>
                    <a href="#" class="designer-menu-item">
                        <div class="designer-menu-item-icon"><i class="bi bi-gear"></i></div>
                        Account Settings
                    </a>
                    <a href="#" class="designer-menu-item">
                        <div class="designer-menu-item-icon"><i class="bi bi-question-circle"></i></div>
                        Help & Support
                    </a>
                    <div class="designer-menu-divider"></div>
                    <a href="{{ path('app_logout') }}" class="designer-menu-item logout-item">
                        <div class="designer-menu-item-icon"><i class="bi bi-box-arrow-left"></i></div>
                        Log out
                    </a>
                </div>
            </div>
        </div>
    </div>
</header>
