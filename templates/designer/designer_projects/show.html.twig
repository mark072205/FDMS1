{% extends 'base.html.twig' %}

{% block title %}{{ project.title }} - Project Details · Mark & Motion{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href=" {{ asset('styles/header.css')}} ">
    <link rel="stylesheet" href=" {{ asset('styles/designer.css')}} ">
{% endblock %}

{% block javascripts %}
    <script src="{{ asset('controllers/designer.js') }}"></script>
{% endblock %}

{% block body %}
{% include 'designer/_headerdesigner.html.twig' with { active: 'projects' } %}

<main class="designer-main">
    <div class="example-wrapper" style="padding: 2rem 1.5rem;">
        <div style="margin-bottom: 2rem;">
            <a href="{{ path('app_designer_projects') }}" style="display: inline-flex; align-items: center; gap: 0.5rem; color: var(--color-primary); text-decoration: none; font-family: 'Poppins', Arial, sans-serif; margin-bottom: 1rem;">
                <i class="bi bi-arrow-left"></i>
                Back to Projects
            </a>
            <h1 style="font-family: 'Poppins', Arial, sans-serif; font-size: 2rem; margin: 0 0 0.5rem 0; color: #111827;">{{ project.title }}</h1>
            <div style="display: flex; gap: 1rem; align-items: center; flex-wrap: wrap;">
                {% set statusClass = project.status == 'completed' ? 'status-completed' : (project.status == 'ongoing' ? 'status-active' : 'status-pending') %}
                <span class="status-badge {{ statusClass }}" style="font-family: 'Montserrat', Arial, sans-serif; font-size: 0.875rem; padding: 0.375rem 0.75rem; border-radius: 12px;">{{ project.status|capitalize }}</span>
                <span style="font-family: 'Montserrat', Arial, sans-serif; color: #6b7280; font-size: 0.875rem;">Posted {{ project.createdAt|date('M d, Y') }}</span>
                {% if project.category %}
                    <span style="font-family: 'Montserrat', Arial, sans-serif; color: #6b7280; font-size: 0.875rem;">• {{ project.category.name }}</span>
                {% endif %}
            </div>
        </div>

        <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 2rem; margin-bottom: 2rem;" class="project-details-grid">
            <!-- Main Content -->
            <div>
                <!-- Project Description -->
                <div style="background: #ffffff; border: 1px solid #e5e7eb; border-radius: 12px; padding: 1.5rem; margin-bottom: 1.5rem;">
                    <h2 style="font-family: 'Poppins', Arial, sans-serif; font-size: 1.25rem; margin: 0 0 1rem 0; color: #111827;">Project Description</h2>
                    <div style="font-family: 'Montserrat', Arial, sans-serif; color: #374151; line-height: 1.8; white-space: pre-wrap;">{{ project.description }}</div>
                </div>

                <!-- Client Information -->
                <div style="background: #ffffff; border: 1px solid #e5e7eb; border-radius: 12px; padding: 1.5rem;">
                    <h2 style="font-family: 'Poppins', Arial, sans-serif; font-size: 1.25rem; margin: 0 0 1rem 0; color: #111827;">Client Information</h2>
                    <div style="display: flex; align-items: center; gap: 1rem;">
                        {% set initials = (project.client.firstName|first|upper) ~ (project.client.lastName|first|upper) %}
                        <div class="author-avatar" style="width: 48px; height: 48px; border-radius: 50%; background: var(--color-primary); color: #ffffff; display: flex; align-items: center; justify-content: center; font-weight: 600; font-size: 1.125rem; font-family: 'Poppins', Arial, sans-serif;">{{ initials }}</div>
                        <div>
                            <div style="font-family: 'Poppins', Arial, sans-serif; font-weight: 600; color: #111827; font-size: 1rem;">{{ project.client.firstName }} {{ project.client.lastName }}</div>
                            <div style="font-family: 'Montserrat', Arial, sans-serif; color: #6b7280; font-size: 0.875rem;">@{{ project.client.username }}</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Sidebar -->
            <div>
                <!-- Project Details Card -->
                <div style="background: #ffffff; border: 1px solid #e5e7eb; border-radius: 12px; padding: 1.5rem; margin-bottom: 1.5rem;">
                    <h2 style="font-family: 'Poppins', Arial, sans-serif; font-size: 1.25rem; margin: 0 0 1.5rem 0; color: #111827;">Project Details</h2>
                    
                    <div style="margin-bottom: 1.25rem;">
                        <div style="font-family: 'Poppins', Arial, sans-serif; font-size: 0.875rem; color: #6b7280; margin-bottom: 0.5rem;">Budget</div>
                        <div style="font-family: 'Montserrat', Arial, sans-serif; font-size: 1.5rem; font-weight: 600; color: #111827;">${{ project.budget|number_format(2, '.', ',') }}</div>
                    </div>

                    {% if project.category %}
                    <div style="margin-bottom: 1.25rem;">
                        <div style="font-family: 'Poppins', Arial, sans-serif; font-size: 0.875rem; color: #6b7280; margin-bottom: 0.5rem;">Category</div>
                        <div style="font-family: 'Montserrat', Arial, sans-serif; font-size: 1rem; color: #111827;">{{ project.category.name }}</div>
                    </div>
                    {% endif %}

                    <div style="margin-bottom: 1.25rem;">
                        <div style="font-family: 'Poppins', Arial, sans-serif; font-size: 0.875rem; color: #6b7280; margin-bottom: 0.5rem;">Status</div>
                        <span class="status-badge {{ statusClass }}" style="font-family: 'Montserrat', Arial, sans-serif; font-size: 0.875rem; padding: 0.375rem 0.75rem; border-radius: 12px;">{{ project.status|capitalize }}</span>
                    </div>

                    <div style="margin-bottom: 1.25rem;">
                        <div style="font-family: 'Poppins', Arial, sans-serif; font-size: 0.875rem; color: #6b7280; margin-bottom: 0.5rem;">Proposals</div>
                        <div style="font-family: 'Montserrat', Arial, sans-serif; font-size: 1rem; color: #111827;">{{ proposalsCount }} proposal{{ proposalsCount != 1 ? 's' : '' }}</div>
                    </div>

                    <div>
                        <div style="font-family: 'Poppins', Arial, sans-serif; font-size: 0.875rem; color: #6b7280; margin-bottom: 0.5rem;">Posted</div>
                        <div style="font-family: 'Montserrat', Arial, sans-serif; font-size: 1rem; color: #111827;">{{ project.createdAt|date('F d, Y') }}</div>
                    </div>
                </div>

                <!-- Action Card -->
                <div style="background: #ffffff; border: 1px solid #e5e7eb; border-radius: 12px; padding: 1.5rem;">
                    {% if existingProposal %}
                        <div style="margin-bottom: 1rem;">
                            <div style="font-family: 'Poppins', Arial, sans-serif; font-size: 0.875rem; color: #6b7280; margin-bottom: 0.5rem;">Your Proposal Status</div>
                            {% set proposalStatusClass = existingProposal.status == 'accepted' ? 'status-completed' : (existingProposal.status == 'rejected' ? 'status-cancelled' : 'status-pending') %}
                            <span class="status-badge {{ proposalStatusClass }}" style="font-family: 'Montserrat', Arial, sans-serif; font-size: 0.875rem; padding: 0.375rem 0.75rem; border-radius: 12px;">{{ existingProposal.status|capitalize }}</span>
                        </div>
                        <a href="#" class="btn btn-primary" style="width: 100%; text-align: center; font-family: 'Poppins', Arial, sans-serif; padding: 0.75rem 1.5rem; text-decoration: none; display: block;">View My Proposal</a>
                    {% else %}
                        <a href="#" class="btn btn-primary" id="submitProposalBtn" style="width: 100%; text-align: center; font-family: 'Poppins', Arial, sans-serif; padding: 0.75rem 1.5rem; text-decoration: none; display: block;">
                            <i class="bi bi-send"></i> Submit Proposal
                        </a>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</main>
{% endblock %}

