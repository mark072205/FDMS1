<!-- Success Modal -->
<div id="proposalSuccessModal" class="project-modal hidden" aria-hidden="true">
    <div class="project-modal__backdrop"></div>
    <div class="project-modal__dialog success-modal-dialog" role="dialog" aria-modal="true" aria-labelledby="successModalTitle" style="max-width: 380px;">
        <div class="success-modal-content">
            <div style="text-align: center; padding: 0.75rem 0 1.25rem;">
                <div style="width: 60px; height: 60px; margin: 0 auto 0.75rem; background: #d1fae5; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                    <i class="bi bi-check-circle-fill" style="font-size: 2.25rem; color: #10b981;"></i>
                </div>
                <h2 id="successModalTitle" class="success-modal-title" style="font-family: 'Poppins', Arial, sans-serif; font-size: 1.25rem; font-weight: 600; color: #111827; margin-bottom: 0.5rem; text-align: center;">Success!</h2>
                <p class="success-modal-message" id="successModalMessage" style="font-family: 'Montserrat', Arial, sans-serif; color: #6b7280; font-size: 0.875rem; line-height: 1.5; text-align: center; margin-bottom: 1.25rem;">Your proposal has been submitted and is now pending review by the client.</p>
            </div>
            <div class="success-modal-footer" style="display: flex; justify-content: center;">
                <button type="button" class="btn btn-primary" id="closeSuccessModal" style="min-width: 100px; padding: 0.5rem 1rem; font-size: 0.875rem;">
                    <span>Got it</span>
                </button>
            </div>
        </div>
    </div>
</div>

