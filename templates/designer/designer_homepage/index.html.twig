{% extends 'base.html.twig' %}

{% block title %}Mark & Motion · Designer{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href=" {{ asset('styles/header.css')}} ">
    <link rel="stylesheet" href=" {{ asset('styles/designer.css')}} ">
    <link rel="stylesheet" href="{{ asset('styles/footer.css') }}">
{% endblock %}

{% block javascripts %}
    <script src="{{ asset('controllers/designer.js') }}"></script>
{% endblock %}

{% block body %}
{% include 'designer/_headerdesigner.html.twig' with { active: 'home' } %}

<main class="designer-main-studio">
    <!-- Hero / Studio Header -->
    <section class="studio-hero">
        <div class="studio-hero-ambient" id="heroAmbientPattern">
            {# Pattern class will be randomly assigned by JavaScript on page load #}
        </div>
        <div class="studio-hero-content">
            <div class="studio-hero-avatar">
                <div class="studio-hero-avatar-circle" style="position: relative; overflow: hidden;">
                    {% if app.user and app.user.profilePicture and app.user.profilePicture|trim != '' %}
                        <img src="{{ asset('uploads/profile_pictures/' ~ app.user.profilePicture) }}?v={{ 'now'|date('U') }}" alt="{{ app.user.firstName }} {{ app.user.lastName }}" style="width: 100%; height: 100%; border-radius: 50%; object-fit: cover; position: absolute; top: 0; left: 0; z-index: 1;" onerror="this.style.display='none'; this.nextElementSibling.style.zIndex='1';">
                    {% endif %}
                    <span style="display: flex; width: 100%; height: 100%; align-items: center; justify-content: center; position: absolute; top: 0; left: 0; z-index: {% if app.user and app.user.profilePicture and app.user.profilePicture|trim != '' %}0{% else %}1{% endif %}; font-size: inherit; color: inherit; font-weight: inherit;">
                        {% if app.user %}
                            {{ app.user.firstName|first|upper }}{{ app.user.lastName|first|upper }}
                        {% else %}
                            AS
                        {% endif %}
                    </span>
                </div>
            </div>
            <h1 class="studio-hero-title">Welcome back, {% if app.user %}{{ app.user.firstName }}{% else %}Aljemark{% endif %}.</h1>
            <p class="studio-hero-subtitle">Discover new opportunities — connect with clients and explore exciting projects.</p>
            <button class="studio-hero-cta"><span>Explore Projects</span></button>
        </div>
    </section>

    <!-- Your Studio Space -->
    <section class="studio-workspace">
        <h2 class="studio-section-title">Your Studio Space</h2>
        <div class="workspace-zones">
            <a href="#" class="workspace-zone">
                <div class="workspace-zone-content">
                    <h3 class="workspace-zone-title">On the Table</h3>
                    <p class="workspace-zone-desc">Ongoing projects</p>
                </div>
                <div class="workspace-zone-preview">
                    <img src="https://via.placeholder.com/60" alt="" class="workspace-thumb">
                </div>
            </a>
            
            <a href="#" class="workspace-zone">
                <div class="workspace-zone-content">
                    <h3 class="workspace-zone-title">In Review</h3>
                    <p class="workspace-zone-desc">Submitted designs awaiting approval</p>
                </div>
                <div class="workspace-zone-preview">
                    <img src="https://via.placeholder.com/60" alt="" class="workspace-thumb">
                </div>
            </a>
            
            <a href="#" class="workspace-zone">
                <div class="workspace-zone-content">
                    <h3 class="workspace-zone-title">Up for Grabs</h3>
                    <p class="workspace-zone-desc">Explore new client projects</p>
                </div>
                <div class="workspace-zone-preview">
                    <img src="https://via.placeholder.com/60" alt="" class="workspace-thumb">
                </div>
            </a>
            
            <a href="#" class="workspace-zone">
                <div class="workspace-zone-content">
                    <h3 class="workspace-zone-title">Archived Works</h3>
                    <p class="workspace-zone-desc">Completed projects</p>
                </div>
                <div class="workspace-zone-preview">
                    <img src="https://via.placeholder.com/60" alt="" class="workspace-thumb">
                </div>
            </a>
        </div>
    </section>

    <!-- Moodboard / Inspiration Wall -->
    <section class="studio-moodboard">
        <div class="moodboard-header">
            <h2 class="studio-section-title">Inspiration Wall</h2>
            <button class="moodboard-filter-btn">
                <i class="bi bi-funnel"></i>
            </button>
        </div>
        <div class="moodboard-container">
            <div class="moodboard-scroll">
                <div class="moodboard-item">
                    <img src="https://via.placeholder.com/200x200" alt="Inspiration">
                    <button class="moodboard-pin-btn"><i class="bi bi-pin-angle"></i></button>
                </div>
                <div class="moodboard-item">
                    <img src="https://via.placeholder.com/200x200" alt="Inspiration">
                    <button class="moodboard-pin-btn"><i class="bi bi-pin-angle"></i></button>
                </div>
                <div class="moodboard-item">
                    <img src="https://via.placeholder.com/200x200" alt="Inspiration">
                    <button class="moodboard-pin-btn"><i class="bi bi-pin-angle"></i></button>
                </div>
                <div class="moodboard-item">
                    <img src="https://via.placeholder.com/200x200" alt="Inspiration">
                    <button class="moodboard-pin-btn"><i class="bi bi-pin-angle"></i></button>
                </div>
                <div class="moodboard-item">
                    <img src="https://via.placeholder.com/200x200" alt="Inspiration">
                    <button class="moodboard-pin-btn"><i class="bi bi-pin-angle"></i></button>
                </div>
                <div class="moodboard-item">
                    <img src="https://via.placeholder.com/200x200" alt="Inspiration">
                    <button class="moodboard-pin-btn"><i class="bi bi-pin-angle"></i></button>
                </div>
            </div>
        </div>
    </section>

    <!-- Studio Feed & Creative Journal -->
    <section class="studio-feed-journal">
        <div class="feed-journal-layout">
            <!-- Studio Feed -->
            <div class="studio-feed">
                <h2 class="studio-section-title">Studio Feed</h2>
                <div class="feed-items">
                    <div class="feed-item">
                        <div class="feed-item-avatar">JT</div>
                        <div class="feed-item-content">
                            <p class="feed-item-text"><strong>Client J. Torres</strong> left feedback on <strong>Brand Identity Mockup</strong>.</p>
                            <span class="feed-item-time">2 hours ago</span>
                        </div>
                    </div>
                    <div class="feed-item">
                        <div class="feed-item-avatar">CI</div>
                        <div class="feed-item-content">
                            <p class="feed-item-text"><strong>Project Coastal Interiors</strong> moved to the next stage.</p>
                            <span class="feed-item-time">5 hours ago</span>
                        </div>
                    </div>
                    <div class="feed-item">
                        <div class="feed-item-avatar">UI</div>
                        <div class="feed-item-content">
                            <p class="feed-item-text">You've been invited to collaborate on <strong>UI Revamp</strong>.</p>
                            <span class="feed-item-time">1 day ago</span>
                        </div>
                    </div>
                    <div class="feed-item">
                        <div class="feed-item-avatar">MM</div>
                        <div class="feed-item-content">
                            <p class="feed-item-text">New branding project opportunity available!</p>
                            <span class="feed-item-time">2 days ago</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Upcoming Tasks -->
            <div class="upcoming-tasks">
                <div class="tasks-header">
                    <h2 class="studio-section-title">Upcoming Deadlines</h2>
                    <a href="#" class="tasks-view-all">View all</a>
                </div>
                <div class="tasks-list">
                    <div class="task-item">
                        <div class="task-priority priority-high"></div>
                        <div class="task-content">
                            <div class="task-main">
                                <h3 class="task-title">Brand Identity Final Review</h3>
                                <p class="task-project">Coffee Shop Branding</p>
                            </div>
                            <div class="task-meta">
                                <span class="task-deadline">
                                    <i class="bi bi-calendar"></i>
                                    Due in 2 days
                                </span>
                                <span class="task-progress">
                                    <span class="progress-bar">
                                        <span class="progress-fill" style="width: 85%"></span>
                                    </span>
                                    <span class="progress-text">85%</span>
                                </span>
                            </div>
                        </div>
                        <div class="task-actions">
                            <button class="task-action-btn"><i class="bi bi-arrow-right"></i></button>
                        </div>
                    </div>
                    
                    <div class="task-item">
                        <div class="task-priority priority-medium"></div>
                        <div class="task-content">
                            <div class="task-main">
                                <h3 class="task-title">Logo Concept Presentation</h3>
                                <p class="task-project">Tech Startup Redesign</p>
                            </div>
                            <div class="task-meta">
                                <span class="task-deadline">
                                    <i class="bi bi-calendar"></i>
                                    Due in 5 days
                                </span>
                                <span class="task-progress">
                                    <span class="progress-bar">
                                        <span class="progress-fill" style="width: 60%"></span>
                                    </span>
                                    <span class="progress-text">60%</span>
                                </span>
                            </div>
                        </div>
                        <div class="task-actions">
                            <button class="task-action-btn"><i class="bi bi-arrow-right"></i></button>
                        </div>
                    </div>
                    
                    <div class="task-item">
                        <div class="task-priority priority-low"></div>
                        <div class="task-content">
                            <div class="task-main">
                                <h3 class="task-title">Color Palette Refinement</h3>
                                <p class="task-project">Fashion Brand Campaign</p>
                            </div>
                            <div class="task-meta">
                                <span class="task-deadline">
                                    <i class="bi bi-calendar"></i>
                                    Due in 1 week
                                </span>
                                <span class="task-progress">
                                    <span class="progress-bar">
                                        <span class="progress-fill" style="width: 40%"></span>
                                    </span>
                                    <span class="progress-text">40%</span>
                                </span>
                            </div>
                        </div>
                        <div class="task-actions">
                            <button class="task-action-btn"><i class="bi bi-arrow-right"></i></button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Spotlight Section -->
    <section class="studio-spotlight">
        <div class="spotlight-header">
            <h2 class="studio-section-title">Spotlight</h2>
            <div class="spotlight-nav">
                <button class="spotlight-nav-btn active" data-slide="1">Featured Work</button>
                <button class="spotlight-nav-btn" data-slide="2">Challenges</button>
                <button class="spotlight-nav-btn" data-slide="3">Opportunities</button>
            </div>
        </div>
        <div class="spotlight-content">
            <div class="spotlight-slide active" data-slide="1">
                <div class="spotlight-card">
                    <div class="spotlight-card-image">
                        <img src="https://via.placeholder.com/300x200" alt="Featured Work">
                    </div>
                    <div class="spotlight-card-content">
                        <h3 class="spotlight-card-title">Modern Minimalist Brand Identity</h3>
                        <p class="spotlight-card-desc">See how Designer Jane crafted a stunning brand identity for a sustainable fashion startup.</p>
                        <a href="#" class="spotlight-card-link">View Case Study <i class="bi bi-arrow-right"></i></a>
                    </div>
                </div>
            </div>
            <div class="spotlight-slide" data-slide="2">
                <div class="spotlight-card">
                    <div class="spotlight-card-image">
                        <img src="https://via.placeholder.com/300x200" alt="Challenge">
                    </div>
                    <div class="spotlight-card-content">
                        <h3 class="spotlight-card-title">Eco-Friendly Packaging Design Challenge</h3>
                        <p class="spotlight-card-desc">Create sustainable packaging for a new product line. Winners get featured and cash prize!</p>
                        <a href="#" class="spotlight-card-link">Accept Challenge <i class="bi bi-arrow-right"></i></a>
                    </div>
                </div>
            </div>
            <div class="spotlight-slide" data-slide="3">
                <div class="spotlight-card">
                    <div class="spotlight-card-image">
                        <img src="https://via.placeholder.com/300x200" alt="Opportunity">
                    </div>
                    <div class="spotlight-card-content">
                        <h3 class="spotlight-card-title">Tech Startup Logo Design</h3>
                        <p class="spotlight-card-desc">Well-funded startup seeking a modern, tech-forward logo design. $5,000 budget.</p>
                        <a href="#" class="spotlight-card-link">View Details <i class="bi bi-arrow-right"></i></a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Studio Vibe (Subtle Insights) -->
    <section class="studio-vibe">
        <div class="vibe-header">
            <h2 class="studio-section-title">This Month's Performance</h2>
            <span class="vibe-period">December 2024</span>
        </div>
        <div class="vibe-content">
            <div class="vibe-stats">
                <div class="vibe-stat-item">
                    <div class="vibe-stat-icon" style="background: linear-gradient(135deg, #1e3a8a, #3b82f6);">
                        <i class="bi bi-briefcase"></i>
                    </div>
                    <div class="vibe-stat-content">
                        <span class="vibe-stat-value">8</span>
                        <span class="vibe-stat-label">Projects Completed</span>
                        <span class="vibe-stat-change positive">+2 from last month</span>
                    </div>
                </div>
                <div class="vibe-stat-item">
                    <div class="vibe-stat-icon" style="background: linear-gradient(135deg, #3b82f6, #60a5fa);">
                        <i class="bi bi-upload"></i>
                    </div>
                    <div class="vibe-stat-content">
                        <span class="vibe-stat-value">24</span>
                        <span class="vibe-stat-label">Designs Uploaded</span>
                        <span class="vibe-stat-change positive">+5 from last month</span>
                    </div>
                </div>
                <div class="vibe-stat-item">
                    <div class="vibe-stat-icon" style="background: linear-gradient(135deg, #60a5fa, #93c5fd);">
                        <i class="bi bi-star-fill"></i>
                    </div>
                    <div class="vibe-stat-content">
                        <span class="vibe-stat-value">4.9</span>
                        <span class="vibe-stat-label">Avg Client Rating</span>
                        <span class="vibe-stat-change positive">+0.2 improvement</span>
                    </div>
                </div>
                <div class="vibe-stat-item">
                    <div class="vibe-stat-icon" style="background: linear-gradient(135deg, #93c5fd, #dbeafe);">
                        <i class="bi bi-clock"></i>
                    </div>
                    <div class="vibe-stat-content">
                        <span class="vibe-stat-value">94%</span>
                        <span class="vibe-stat-label">On-Time Delivery</span>
                        <span class="vibe-stat-change positive">+3% improvement</span>
                    </div>
                </div>
            </div>
            <div class="vibe-momentum-card">
                <div class="momentum-header">
                    <span class="momentum-label">Creative Momentum</span>
                    <span class="momentum-status">Strong</span>
                </div>
                <div class="momentum-meter">
                    <div class="momentum-bar" style="width: 82%;">
                        <div class="momentum-glow"></div>
                    </div>
                </div>
                <p class="momentum-description">You're maintaining excellent workflow consistency this month</p>
            </div>
        </div>
    </section>
</main>

{% include 'designer/_footerdesigner.html.twig' with { active: 'home' } %}

{% endblock %}
