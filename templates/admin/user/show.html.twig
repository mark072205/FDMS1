{% extends 'base.html.twig' %}

{% block title %}{{ user.firstName }} {{ user.lastName }} - User Details · Admin{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href=" {{ asset('styles/admin.css')}} ">
{% endblock %}

{% block body %}
    {% include 'admin/_header.html.twig' with { active: 'users' } %}
    
    <div class="admin-container">
        <div class="admin-header">
            <div style="display: flex; align-items: center; gap: 1rem;">
                {% set roleType = (user.userType is defined and user.userType ? user.userType : (user.role is defined ? user.role : 'admin'))|lower %}
                <div class="profile-avatar {{ roleType == 'designer' ? 'is-designer' : (roleType == 'client' ? 'is-client' : 'is-admin') }}" style="width: 60px; height: 60px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; color: #ffffff; font-weight: bold; font-family: 'Poppins', Arial, sans-serif; flex-shrink: 0;">
                    {% if user.profilePicture %}
                        <img src="{{ asset('uploads/profile_pictures/' ~ user.profilePicture) }}" alt="{{ user.firstName }} {{ user.lastName }}" style="width: 100%; height: 100%; border-radius: 50%; object-fit: cover;">
                    {% else %}
                        {{ user.firstName|first|upper }}{{ user.lastName|first|upper }}
                    {% endif %}
                </div>
                <div>
                    <h1 class="admin-title">{{ user.firstName }} {{ user.lastName }}</h1>
                    <p class="admin-subtitle">{{ user.userType|title }}</p>
                </div>
            </div>
            <div class="admin-toolbar">
                <a class="btn-secondary" href="{{ path('app_user_index') }}">← Back to Users</a>
                {% if user.username != 'admin' %}
                    <button class="btn-icon toggle-status {{ user.isActive ? 'btn-danger' : 'btn-success' }}" 
                            data-user-id="{{ user.id }}" 
                            data-current-status="{{ user.isActive ? 'active' : 'inactive' }}"
                            title="{{ user.isActive ? 'Disable User' : 'Enable User' }}">
                        <i class="bi bi-{{ user.isActive ? 'person-x' : 'person-check' }}"></i>
                    </button>
                    <button class="btn-icon toggle-verification {{ user.verified ? 'btn-warning' : 'btn-success' }}" 
                            data-user-id="{{ user.id }}" 
                            data-current-verified="{{ user.verified ? 'verified' : 'unverified' }}"
                            title="{{ user.verified ? 'Unverify User' : 'Verify User' }}">
                        <i class="bi bi-{{ user.verified ? 'shield-x' : 'shield-check' }}"></i>
                    </button>
                {% endif %}
            </div>
        </div>

        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert {{ label == 'success' ? 'alert-success' : (label == 'error' ? 'alert-error' : '') }}">{{ message }}</div>
            {% endfor %}
        {% endfor %}

        <div class="admin-card" style="padding: 1.1rem 1.25rem; margin-bottom: 2rem;">
            <h2 style="font-family:'Poppins'; font-size:1.2rem; margin: 0 0 0.9rem 0;">User Information</h2>
            <div class="admin-table-wrapper">
                <table class="admin-table table-balanced table-colored">
                    <thead>
                        <tr>
                            <th class="col-title">Field</th>
                            <th class="col-category">Value</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr class="admin-row">
                            <td><strong>Username</strong></td>
                            <td>{{ user.username }}</td>
                        </tr>
                        <tr class="admin-row">
                            <td><strong>Email</strong></td>
                            <td>{{ user.email }}</td>
                        </tr>
                        <tr class="admin-row">
                            <td><strong>First Name</strong></td>
                            <td>{{ user.firstName }}</td>
                        </tr>
                        <tr class="admin-row">
                            <td><strong>Last Name</strong></td>
                            <td>{{ user.lastName }}</td>
                        </tr>
                        <tr class="admin-row">
                            <td><strong>User Type</strong></td>
                            <td>
                                {% set userTypeClass = user.userType == 'admin' ? 'badge-danger' : (user.userType == 'designer' ? 'badge-warning' : 'badge-info') %}
                                <span class="badge {{ userTypeClass }}">{{ user.userType|title }}</span>
                            </td>
                        </tr>
                        <tr class="admin-row">
                            <td><strong>Role</strong></td>
                            <td><span class="badge badge-secondary">{{ user.role|title }}</span></td>
                        </tr>
                        <tr class="admin-row">
                            <td><strong>Status</strong></td>
                            <td>
                                {% set statusClass = user.isActive ? 'is-active' : 'is-inactive' %}
                                <span class="badge-status {{ statusClass }}" id="status-{{ user.id }}">{{ user.isActive ? 'Active' : 'Disabled' }}</span>
                            </td>
                        </tr>
                        <tr class="admin-row">
                            <td><strong>Verified</strong></td>
                            <td>
                                {% set verifiedClass = user.verified ? 'is-active' : 'is-pending' %}
                                <span class="badge-status {{ verifiedClass }}" id="verified-status-{{ user.id }}">{{ user.verified ? 'Verified' : 'Unverified' }}</span>
                            </td>
                        </tr>
                        {% if user.bio %}
                        <tr class="admin-row">
                            <td><strong>Bio</strong></td>
                            <td>{{ user.bio }}</td>
                        </tr>
                        {% endif %}
                    </tbody>
                </table>
            </div>
        </div>

        <div class="admin-card" style="padding: 1.1rem 1.25rem; margin-bottom: 2rem;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.9rem;">
                <h2 style="font-family:'Poppins'; font-size:1.2rem; margin: 0;">Password Information</h2>
            </div>
            <div class="admin-table-wrapper">
                <table class="admin-table table-balanced table-colored">
                    <thead>
                        <tr>
                            <th class="col-title">Field</th>
                            <th class="col-category">Value</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr class="admin-row">
                            <td><strong>Password (Encrypted)</strong></td>
                            <td>
                                <div class="password-display">
                                    <code class="password-hash">{{ user.password }}</code>
                                    <button class="btn-link copy-btn" onclick="copyToClipboard('{{ user.password }}')">Copy</button>
                                </div>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <div class="admin-card" style="padding: 1.1rem 1.25rem; margin-bottom: 2rem;">
            <h2 style="font-family:'Poppins'; font-size:1.2rem; margin: 0 0 0.9rem 0;">Activity Timeline</h2>
            <div class="admin-table-wrapper">
                <table class="admin-table table-balanced table-colored">
                    <thead>
                        <tr>
                            <th class="col-title">Event</th>
                            <th class="col-date">Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr class="admin-row">
                            <td><strong>Account Created</strong></td>
                            <td>{{ user.createdAt|date('Y-m-d H:i') }}</td>
                        </tr>
                        {% if user.lastLogin %}
                        <tr class="admin-row">
                            <td><strong>Last Login</strong></td>
                            <td>{{ user.lastLogin|date('Y-m-d H:i') }}</td>
                        </tr>
                        {% endif %}
                        {% if user.lastActivity %}
                        <tr class="admin-row">
                            <td><strong>Last Activity</strong></td>
                            <td>{{ user.lastActivity|date('Y-m-d H:i') }}</td>
                        </tr>
                        {% endif %}
                        {% if user.updatedAt %}
                        <tr class="admin-row">
                            <td><strong>Last Updated</strong></td>
                            <td>{{ user.updatedAt|date('Y-m-d H:i') }}</td>
                        </tr>
                        {% endif %}
                    </tbody>
                </table>
            </div>
            <div style="margin-top: 1rem;">
                <button class="btn-secondary" onclick="updateActivity({{ user.id }})">Update Activity</button>
            </div>
        </div>
    </div>

    <script>
        // Wait for DOM to be ready
        document.addEventListener('DOMContentLoaded', function() {
            let currentUserId = {{ user.id }};
            console.log('DOM loaded, currentUserId:', currentUserId);
        });
        
        // Copy to clipboard function
        function copyToClipboard(text) {
            if (window.adminManager) {
                window.adminManager.copyToClipboard(text, 'Password hash copied to clipboard!');
            } else {
                navigator.clipboard.writeText(text).then(function() {
                    showAlert('success', 'Password hash copied to clipboard!');
                }, function(err) {
                    console.error('Could not copy text: ', err);
                    showAlert('error', 'Failed to copy to clipboard');
                });
            }
        }

        // Update activity function
        function updateActivity(userId) {
            if (window.adminManager) {
                window.adminManager.updateUserActivity(userId, true);
            } else {
                fetch(`/admin/users/${userId}/update-activity`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    }
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        showAlert('success', data.message);
                        // Reload page to show updated activity
                        setTimeout(() => {
                            location.reload();
                        }, 1000);
                    } else {
                        showAlert('error', data.message);
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    showAlert('error', 'An error occurred while updating activity.');
                });
            }
        }
    </script>

{% endblock %}

{% block javascripts %}
    <script src="{{ asset('controllers/search_controller.js') }}"></script>
    <script src="{{ asset('controllers/admin.js') }}"></script>
{% endblock %}