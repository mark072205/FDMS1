{% extends 'base.html.twig' %}

{% block title %}User Management · Admin{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href=" {{ asset('styles/admin.css')}} ">
    <style>
        /* Simple fix for Actions column centering */
        #usersTable td:last-child,
        #usersTable th:last-child {
            text-align: center !important;
        }
    </style>
{% endblock %}

{% block body %}
    {% include 'admin/_header.html.twig' with { active: 'users' } %}
    
    <div class="admin-container">
        <div class="admin-header">
            <div>
                <h1 class="admin-title">Users</h1>
                <p class="admin-subtitle">Manage system users and their permissions</p>
            </div>
            <div class="admin-toolbar">
            </div>
        </div>

        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert {{ label == 'success' ? 'alert-success' : (label == 'error' ? 'alert-error' : '') }}">{{ message }}</div>
            {% endfor %}
        {% endfor %}

        <div class="admin-card" style="padding: 1.1rem 1.25rem;">
            <h2 style="font-family:'Poppins'; font-size:1.2rem; margin: 0 0 0.9rem 0;">All Users</h2>
            <div class="admin-table-wrapper-disable">
                <table class="admin-table table-balanced table-colored" id="usersTable">
                    <thead>
                        <tr>
                            <th class="col-id" style="width: 40px; font-size: 0.75rem; padding: 4px 6px;">ID</th>
                            <th style="width: 80px; font-size: 0.75rem; text-align: center !important; padding: 4px 6px;">First Name</th>
                            <th class="col-title" style="width: 80px; font-size: 0.75rem; padding: 4px 6px;">Last Name</th>
                            <th class="col-title" style="width: 80px; font-size: 0.75rem; padding: 4px 6px;">Username</th>
                            <th class="col-title" style="width: 140px; font-size: 0.75rem; padding: 4px 6px;">Email</th>
                            <th class="col-category" style="text-align: center; width: 60px; font-size: 0.75rem; padding: 4px 6px;">Type</th>
                            <th class="col-status" style="width: 60px; font-size: 0.75rem; padding: 4px 6px;">Status</th>
                            <th class="col-status" style="width: 60px; font-size: 0.75rem; padding: 4px 6px;">Verified</th>
                            <th class="col-date" style="width: 80px; font-size: 0.75rem; padding: 4px 6px;">Created</th>
                            <th style="width: 60px; font-size: 0.75rem; padding: 4px 6px; text-align: center;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for user in users %}
                            <tr class="admin-row" data-user-id="{{ user.id }}">
                                <td style="font-size: 0.75rem; white-space: nowrap; padding: 4px 6px;">{{ user.id }}</td>
                                <td style="font-size: 0.75rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; text-align: center !important; padding: 4px 6px;" title="{{ user.firstName }}">{{ user.firstName }}</td>
                                <td style="font-size: 0.75rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; padding: 4px 6px;" title="{{ user.lastName }}">{{ user.lastName }}</td>
                                <td style="font-size: 0.75rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; padding: 4px 6px;" title="@{{ user.username }}">@{{ user.username }}</td>
                                <td style="font-size: 0.75rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 140px; padding: 4px 6px;" title="{{ user.email }}">{{ user.email }}</td>
                                <td style="text-align: center !important; padding: 4px 6px;">
                                    {% set userTypeClass = user.userType == 'admin' ? 'badge-danger' : (user.userType == 'designer' ? 'badge-warning' : 'badge-info') %}
                                    <span class="badge {{ userTypeClass }}" style="font-size: 0.6rem; padding: 2px 6px; white-space: nowrap;">{{ user.userType|title }}</span>
                                </td>
                                <td style="padding: 4px 6px;">
                                    {% set statusClass = user.isActive ? 'is-active' : 'is-inactive' %}
                                    <span class="badge-status {{ statusClass }}" id="status-{{ user.id }}" style="font-size: 0.6rem; padding: 2px 6px; white-space: nowrap;">{{ user.isActive ? 'Active' : 'Disabled' }}</span>
                                </td>
                                <td style="padding: 4px 6px;">
                                    {% set verifiedClass = user.verified ? 'is-active' : 'is-pending' %}
                                    <span class="badge-status {{ verifiedClass }}" id="verified-{{ user.id }}" style="font-size: 0.6rem; padding: 2px 6px; white-space: nowrap;">{{ user.verified ? 'Verified' : 'Unverified' }}</span>
                                </td>
                                <td style="font-size: 0.75rem; white-space: nowrap; padding: 4px 6px;">{{ user.createdAt|date('Y-m-d') }}</td>
                                <td style="padding: 4px 6px; text-align: center;">
                                    <a class="btn-link" href="{{ path('app_user_show', {'id': user.id}) }}" style="font-size: 0.8rem; padding: 3px 6px; margin: 0; display: inline-block; border-radius: 4px;">View</a>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="10">No users found.</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

{% endblock %}

{% block javascripts %}
    <script src="{{ asset('controllers/search_controller.js') }}"></script>
    <script src="{{ asset('controllers/admin.js') }}"></script>
{% endblock %}
