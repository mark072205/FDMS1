<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="csrf-token" content="{{ csrf_token('authenticate') }}">
    <title>Dashboard Overview · Admin</title>
    <link rel="icon" href="{{ asset('favicon.ico') }}">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="{{ asset('styles/admin.css') }}">
    <script src="{{ asset('controllers/search_controller.js') }}" defer></script>
</head>
<body>
<script>
// Toggle the admin dropdown and chevron (if present)
function toggleDropdown() {
    const dropdown = document.getElementById('adminDropdown');
    const chevronIcon = document.getElementById('chevronIcon');

    if (!dropdown) {
        console.log('Dropdown not found');
        return;
    }

    console.log('Toggling dropdown');
    dropdown.classList.toggle('show');

    if (chevronIcon) {
        chevronIcon.className = dropdown.classList.contains('show') ? 'bi bi-chevron-up chevron-icon' : 'bi bi-chevron-down chevron-icon';
    }
}

// Make toggleDropdown globally accessible
window.toggleDropdown = toggleDropdown;

// Close dropdown when clicking outside the badge
document.addEventListener('click', function(event) {
    const dropdown = document.getElementById('adminDropdown');
    const badge = document.querySelector('.admin-badge');
    const chevronIcon = document.getElementById('chevronIcon');

    if (!badge || !dropdown) {
        console.log('Badge or dropdown not found:', { badge: !!badge, dropdown: !!dropdown });
        return;
    }

    if (!badge.contains(event.target)) {
        dropdown.classList.remove('show');
        if (chevronIcon) chevronIcon.className = 'bi bi-chevron-down chevron-icon';
    }
});

// Debug: Check if elements exist on page load
document.addEventListener('DOMContentLoaded', function() {
    const dropdown = document.getElementById('adminDropdown');
    const badge = document.querySelector('.admin-badge');
    console.log('Admin dropdown elements:', { dropdown: !!dropdown, badge: !!badge });
    
    if (dropdown) {
        console.log('Dropdown classes:', dropdown.className);
    }
});

function showDeleteModal() {
    document.getElementById('deleteModal').classList.add('show');
}

function hideDeleteModal() {
    document.getElementById('deleteModal').classList.remove('show');
}

function confirmDelete() {
    document.getElementById('deleteForm').submit();
}

// Close modal when clicking outside
document.addEventListener('click', function(event) {
    const modal = document.getElementById('deleteModal');
    if (event.target === modal) {
        hideDeleteModal();
    }
});

document.querySelectorAll('.admin-table td.desc-col').forEach(cell => {
if (cell.scrollHeight > cell.clientHeight + 2) {
    cell.classList.add('multiline');
}
});

function adjustRowAlignment() {
    document.querySelectorAll(".admin-table tbody tr").forEach(row => {
        const idCell   = row.querySelector("td:nth-child(1)");
        const nameCell = row.querySelector("td:nth-child(2)");
        const descCell = row.querySelector("td:nth-child(3)");
        if (!idCell || !nameCell || !descCell) return;

        function getLineCount(cell) {
            const cs = window.getComputedStyle(cell);
            let lineHeight = parseFloat(cs.lineHeight);
            if (isNaN(lineHeight) || cs.lineHeight === "normal") {
                lineHeight = parseFloat(cs.fontSize) * 1.2;
            }
            const paddingTop = parseFloat(cs.paddingTop) || 0;
            const paddingBottom = parseFloat(cs.paddingBottom) || 0;
            const contentHeight = cell.scrollHeight - paddingTop - paddingBottom;
            return Math.round(contentHeight / lineHeight);
        }

        const idLines   = getLineCount(idCell);
        const nameLines = getLineCount(nameCell);
        const descLines = getLineCount(descCell);

        // reset first
        [idCell, nameCell, descCell].forEach(c => c.classList.remove("va-top"));

        // if ANY of them is multiline → top align all
        if (idLines > 1 || nameLines > 1 || descLines > 1) {
            [idCell, nameCell, descCell].forEach(c => c.classList.add("va-top"));
        }
    });
}

document.addEventListener("DOMContentLoaded", adjustRowAlignment);
window.addEventListener("resize", adjustRowAlignment);

// Prevent back button after logout
function preventBackButton() {
    window.history.forward();
}

// Initialize back button prevention
preventBackButton();
window.onload = preventBackButton;
window.onpageshow = function(evt) { 
    if (evt.persisted) preventBackButton(); 
}
</script>
    {% include 'admin/_header.html.twig' with { active: 'dashboard' } %}

    <div class="admin-container">
        <div class="admin-header">
            <div>
                <h1 class="admin-title" style="font-family:'Montserrat', Arial, sans-serif;">Welcome, Admin!</h1>
                <p class="admin-subtitle">Dashboard Overview</p>
            </div>
            <div class="admin-toolbar quick-actions">
                <a href="{{ path('app_category_new') }}" class="btn-secondary"><i class="bi bi-plus-lg"></i> Add new Category</a>
                {# <a href="#" class="btn-primary" aria-disabled="true" style="opacity:.6; pointer-events:none;"><i class="bi bi-plus-lg"></i> Add new Project</a> #}
                <a href="{{ path('app_user_index') }}" class="btn-outline-purple"><i class="bi bi-gear"></i> Manage Users</a>
            </div>
        </div>

        <!-- Stats Cards -->
        <div class="dashboard-cards" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1.5rem; margin-bottom: 2rem;">
            <div class="admin-card stat-card">
                <div class="stat-icon orange"><i class="bi bi-folder-fill"></i></div>
                <p class="stat-value">{{ totalProjects|default(0) }}</p>
                <div class="stat-label">Projects</div>
            </div>
            <div class="admin-card stat-card">
                <div class="stat-icon blue"><i class="bi bi-tags-fill"></i></div>
                <p class="stat-value">{{ totalCategories|default(0) }}</p>
                <div class="stat-label">Categories</div>
            </div>
            <div class="admin-card stat-card">
                <div class="stat-icon teal"><i class="bi bi-people-fill"></i></div>
                <p class="stat-value">{{ totalUsers|default(0) }}</p>
                <div class="stat-label">Users</div>
            </div>
            <div class="admin-card stat-card">
                <div class="stat-icon pink"><i class="bi bi-check-circle-fill"></i></div>
                <p class="stat-value">{{ completedProjects|default(0) }}</p>
                <div class="stat-label">Completed</div>
            </div>
        </div>

        <!-- User Activity Summary -->
        <div class="admin-card user-activity-summary">
            <div class="activity-header">
                <h2 class="activity-title">
                    <i class="bi bi-graph-up"></i>
                    User Activity Summary
                </h2>
                <div class="activity-period">
                    <span class="period-label">Last 7 days</span>
                </div>
            </div>
            
            <!-- Enhanced User Stats Grid -->
            <div class="user-stats-grid">
                <div class="user-metric enhanced-metric">
                    <div class="metric-icon blue">
                        <i class="bi bi-person-check-fill"></i>
                    </div>
                    <div class="metric-content">
                        <div class="metric-value-row">
                            <p class="metric-value">{{ activeUsers }}</p>
                            <div class="metric-trend positive">
                                <i class="bi bi-arrow-up"></i>
                            </div>
                        </div>
                        <div class="metric-label">Active Users</div>
                        <div class="metric-subtitle">Last 7 days</div>
                    </div>
                </div>
                
                <div class="user-metric enhanced-metric">
                    <div class="metric-icon orange">
                        <i class="bi bi-clock-fill"></i>
                    </div>
                    <div class="metric-content">
                        <div class="metric-value-row">
                            <p class="metric-value">{{ pendingVerifications }}</p>
                            <div class="metric-trend negative">
                                <i class="bi bi-arrow-down"></i>
                            </div>
                        </div>
                        <div class="metric-label">Pending</div>
                        <div class="metric-subtitle">Awaiting approval</div>
                    </div>
                </div>
                
                <div class="user-metric enhanced-metric">
                    <div class="metric-icon green">
                        <i class="bi bi-people-fill"></i>
                    </div>
                    <div class="metric-content">
                        <div class="metric-value-row">
                            <p class="metric-value">{{ totalUsers }}</p>
                            <div class="metric-trend positive">
                                <i class="bi bi-arrow-up"></i>
                            </div>
                        </div>
                        <div class="metric-label">Total Users</div>
                        <div class="metric-subtitle">All time</div>
                    </div>
                </div>
                
                <div class="user-metric enhanced-metric">
                    <div class="metric-icon purple">
                        <i class="bi bi-calendar-check-fill"></i>
                    </div>
                    <div class="metric-content">
                        <div class="metric-value-row">
                            <p class="metric-value">{{ recentLogins|length }}</p>
                            <div class="metric-trend positive">
                                <i class="bi bi-arrow-up"></i>
                            </div>
                        </div>
                        <div class="metric-label">Recent Logins</div>
                        <div class="metric-subtitle">Today</div>
                    </div>
                </div>
            </div>

            <!-- Enhanced User Role Distribution -->
            <div class="role-distribution-section">
                <div class="section-header">
                    <h3 class="section-title">
                        <i class="bi bi-diagram-3-fill"></i>
                        User Role Distribution
                    </h3>
                    <div class="role-summary">
                        <span class="total-roles">{{ usersByRole|length }} roles</span>
                    </div>
                </div>
                <div class="role-distribution-grid">
                    {% for roleData in usersByRole %}
                        <div class="role-card">
                            <div class="role-icon">
                                {% if roleData.role|lower == 'designer' %}
                                    <i class="bi bi-palette-fill"></i>
                                {% elseif roleData.role|lower == 'client' %}
                                    <i class="bi bi-person-badge-fill"></i>
                                {% else %}
                                    <i class="bi bi-person-fill"></i>
                                {% endif %}
                            </div>
                            <div class="role-info">
                                <span class="role-name">{{ roleData.role|capitalize }}</span>
                                <span class="role-count">{{ roleData.count }} users</span>
                            </div>
                            <div class="role-percentage">
                                {{ ((roleData.count / totalUsers) * 100)|round(1) }}%
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </div>

            <!-- Enhanced Recent Logins -->
            <div class="recent-logins-section">
                <div class="section-header">
                    <h3 class="section-title">
                        <i class="bi bi-clock-history"></i>
                        Recent Activity
                    </h3>
                    <a href="{{ path('app_user_index') }}" class="view-all-link">
                        View All Users
                        <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
                <div class="recent-logins-container">
                    {% if recentLogins|length > 0 %}
                        <div class="logins-list">
                            {% for user in recentLogins %}
                                <div class="login-item">
                                    {% set roleType = (user.userType is defined and user.userType ? user.userType : (user.role is defined ? user.role : 'admin'))|lower %}
                                    <div class="user-avatar {{ roleType == 'designer' ? 'is-designer' : (roleType == 'client' ? 'is-client' : 'is-admin') }}" style="width: 40px; height: 40px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1rem; color: #ffffff; font-weight: bold; font-family: 'Poppins', Arial, sans-serif;">
                                        {% if user.profilePicture %}
                                            <img src="{{ asset('uploads/profile_pictures/' ~ user.profilePicture) }}" alt="{{ user.username }}" style="width: 100%; height: 100%; border-radius: 50%; object-fit: cover;">
                                        {% else %}
                                            <span class="avatar-text">{{ user.firstName|first|upper }}{{ user.lastName|first|upper }}</span>
                                        {% endif %}
                                    </div>
                                    <div class="user-details">
                                        <div class="user-name">{{ user.username }}</div>
                                        <div class="user-role">{{ user.role|capitalize }}</div>
                                    </div>
                                    <div class="login-info">
                                        <div class="login-time">{{ user.lastLogin|date('M d, H:i') }}</div>
                                        <div class="login-status">
                                            {% if user.verified %}
                                                <span class="status-badge verified">
                                                    <i class="bi bi-check-circle-fill"></i>
                                                    Verified
                                                </span>
                                            {% else %}
                                                <span class="status-badge pending">
                                                    <i class="bi bi-clock-fill"></i>
                                                    Pending
                                                </span>
                                            {% endif %}
                                        </div>
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                    {% else %}
                        <div class="empty-state">
                            <i class="bi bi-person-x"></i>
                            <p>No recent activity found</p>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>

        {# <!-- Recent Projects -->
        <div class="admin-card" style="padding: 1.1rem 1.25rem; margin-bottom: 2rem;">
            <h2 style="font-family:'Poppins'; font-size:1.2rem; margin: 0 0 0.9rem 0;">Recent Projects</h2>
            <div class="admin-table-wrapper">
                <table class="admin-table table-balanced table-colored">
                    <thead>
                        <tr>
                            <th class="col-id">ID</th>
                            <th class="col-title">Project Title</th>
                            <th class="col-category">Category</th>
                            <th class="col-status">Status</th>
                            <th class="col-date">Created At</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for project in recentProjects %}
                            <tr class="admin-row">
                                <td>{{ project.id }}</td>
                                <td><span class="truncate" title="{{ project.title }}">{{ project.title }}</span></td>
                                <td><span class="truncate" title="{{ project.category.name|default('—') }}">{{ project.category.name|default('—') }}</span></td>
                                <td>
                                    {% set status = project.status|lower %}
                                    {% set cls =
                                        status == 'completed' ? 'is-completed' :
                                        (status == 'ongoing' ? 'is-ongoing' :
                                        (status == 'pending' ? 'is-pending' : 'is-cancelled'))
                                    %}
                                    <span class="badge-status {{ cls }}">{{ project.status|capitalize }}</span>
                                </td>
                                <td>{{ project.createdAt|date('Y-m-d') }}</td>
                            </tr>
                        {% else %}
                            <tr><td colspan="5" style="text-align:center; color:#6b7280;">No recent projects found.</td></tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div> #}

    </div>
</body>
</html>