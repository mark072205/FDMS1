{% extends 'base.html.twig' %}

{% block title %}Mark & Motion | Creativity in Motion, Marks that Last{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/header.css') }}" data-turbo-track="reload">
    <link rel="stylesheet" href="{{ asset('styles/landing.css') }}" data-turbo-track="reload">
    <link rel="stylesheet" href="{{ asset('styles/footer.css') }}" data-turbo-track="reload">
{% endblock %}

{% block body %}
<div>
<script>
document.addEventListener('DOMContentLoaded', function() {
    console.log('Landing page loaded');
    
    // Simple scrollspy implementation
    const navLinks = document.querySelectorAll('.admin-nav .nav-item[href^="#"]');
    const sections = document.querySelectorAll('section[id], footer[id]');
    
    console.log('Found nav links:', navLinks.length);
    console.log('Found sections:', sections.length);
    
    function updateActiveNav() {
        let current = '';
        const scrollY = window.scrollY;
        const windowHeight = window.innerHeight;
        
        // Check all sections including the about (CTA) section
        sections.forEach(section => {
            const sectionTop = section.offsetTop - 100;
            const sectionHeight = section.offsetHeight;
            
            if (scrollY >= sectionTop && scrollY < sectionTop + sectionHeight) {
                current = section.getAttribute('id');
            }
        });
        
        navLinks.forEach(link => {
            link.classList.remove('active');
            if (link.getAttribute('href') === '#' + current) {
                link.classList.add('active');
                console.log('Set active:', current);
            }
        });
    }
    
    window.addEventListener('scroll', updateActiveNav);
    updateActiveNav();
    
    // Prevent navigation links from changing URL
    navLinks.forEach(link => {
        link.addEventListener('click', function(e) {
            e.preventDefault();
            const targetId = this.getAttribute('href').substring(1);
            const targetElement = document.getElementById(targetId);
            
            if (targetElement) {
                const header = document.querySelector('.header');
                const headerHeight = header ? header.offsetHeight : 62;
                const headerOffset = headerHeight + 20; // Header height + extra spacing
                const elementPosition = targetElement.getBoundingClientRect().top;
                const offsetPosition = elementPosition + window.pageYOffset - headerOffset;
                
                window.scrollTo({
                    top: Math.max(0, offsetPosition),
                    behavior: 'smooth'
                });
            }
        });
    });
    
    // Handle smooth scrolling for Learn More button and other anchor links
    const anchorLinks = document.querySelectorAll('a[href^="#"]');
    anchorLinks.forEach(link => {
        link.addEventListener('click', function(e) {
            const href = this.getAttribute('href');
            if (href === '#how-it-works' || href === '#about' || href === '#categories' || href === '#home' || href === '#reviews') {
                e.preventDefault();
                const targetId = href.substring(1);
                const targetElement = document.getElementById(targetId);
                
                if (targetElement) {
                    const header = document.querySelector('.header');
                    const headerHeight = header ? header.offsetHeight : 62;
                    const headerOffset = headerHeight + 20; // Header height + extra spacing
                    const elementPosition = targetElement.getBoundingClientRect().top;
                    const offsetPosition = elementPosition + window.pageYOffset - headerOffset;
                    
                    window.scrollTo({
                        top: Math.max(0, offsetPosition),
                        behavior: 'smooth'
                    });
                }
            }
        });
    });
    
    // Segment tabs functionality
    const segmentTabs = document.querySelectorAll('.segment-tab');
    segmentTabs.forEach(tab => {
        tab.addEventListener('click', function() {
            segmentTabs.forEach(t => {
                t.classList.remove('active');
                t.setAttribute('aria-selected', 'false');
            });
            
            this.classList.add('active');
            this.setAttribute('aria-selected', 'true');
            
            const selectedTab = this.getAttribute('data-tab');
            
            document.querySelectorAll('.tab-content').forEach(content => {
                content.classList.remove('active');
            });
            
            const contentToShow = document.getElementById(selectedTab + '-content');
            if (contentToShow) {
                contentToShow.classList.add('active');
            }
        });
    });
});
</script>
<!-- Header (admin layout applied) -->
<header class="header" id="mainNav">
    <div class="header-left">
        <a href="/" class="logo-link">
            <img src="{{ asset('img/logomain.png') }}" alt="Mark & Motion">
        </a>

        <nav class="admin-nav" aria-label="Main navigation">
            <a href="#home" class="nav-item">Home</a>
            <a href="#categories" class="nav-item">Explore</a>
            <a href="#reviews" class="nav-item">Reviews</a>
            <a href="#how-it-works" class="nav-item">How It Works</a>
            <a href="#about" class="nav-item">About</a>
        </nav>
    </div>

    <div class="header-right">
        <a href="{{ path('app_login') }}" class="btn btn-outline">Log In</a>
        <a href="{{ path('app_signup') }}" class="btn btn-primary">Sign Up</a>
    </div>
</header>

<!-- Hero Section -->
<section class="hero" id="home" data-turbo="false">
    <div class="hero-container-centered">
        <h1 class="hero-heading">Empowering connections between clients and designers.</h1>
        
        <div class="hero-panel">
            <div class="segment-tabs" role="tablist" aria-label="Hero options">
                <button class="segment-tab active" data-tab="find-talent" role="tab" aria-selected="true">Find designer</button>
                <button class="segment-tab" data-tab="browse-jobs" role="tab" aria-selected="false">Browse projects</button>
            </div>

            {# Find Talent Content (shown by default) #}
            <div class="tab-content active" id="find-talent-content">
                <div class="search-box" role="search">
                    <input type="text" placeholder="Search by design category or expertise" aria-label="Search input">
                    <button type="button" class="search-button" aria-label="Search">
                        <span class="search-icon-badge"><i class="bi bi-search"></i></span>
                        <span class="search-button-text">Search</span>
                    </button>
                </div>
                
                <p class="hero-description" style="margin-top: 16px;">
                    Discover talented designer ready to bring your vision to life.
                </p>
            </div>

            {# Browse Jobs Content (hidden by default) #}
            <div class="tab-content" id="browse-jobs-content">
                <p class="hero-description">
                    Build your designing career on Mark & Motion, with thousands of projects posted every week.
                </p>

                <div class="hero-cta">
                    <a href="#" class="btn-cta-green">Explore recently posted projects</a>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Categories Section -->
<section class="categories-section" id="categories">
    <div class="section-header">
        <h2>Explore our design categories</h2>
        <p>Browse through thousands of talented designers ready to bring your vision to life</p>
    </div>
    
    <div class="categories-grid">
        {% if categories is not empty %}
            {% for category in categories %}
                <a href="javascript:void(0)" class="category-card">
                    {% set iconMap = {
                        'Logo Design': 'bi-brush',
                        'Brand Identity': 'bi-palette',
                        'UI/UX Design': 'bi-layout-text-window-reverse',
                        'Graphic Design': 'bi-image',
                        'Illustration': 'bi-pen',
                        'Print Design': 'bi-printer',
                        'Packaging Design': 'bi-box-seam',
                        'Motion Graphics': 'bi-camera-video',
                        'Web Design': 'bi-window',
                        'App Design': 'bi-phone',
                        'Marketing Design': 'bi-megaphone',
                        'Photography': 'bi-camera',
                        'Video Editing': 'bi-film',
                        '3D Design': 'bi-box',
                        'Animation': 'bi-play-circle',
                        'Icon Design': 'bi-circle-square'
                    } %}
                    <i class="bi {{ iconMap[category.name] ?? 'bi-star' }}"></i>
                    <h3>{{ category.name }}</h3>
                    <p>{{ category.description }}</p>
                </a>
            {% endfor %}
        {% else %}
            <div style="text-align: center; padding: 40px; grid-column: 1 / -1;">
                <p>No categories available yet. Check back soon!</p>
            </div>
        {% endif %}
    </div>
</section>

