<!-- Notification Dropdown -->
<div id="notificationDropdown" class="notification-dropdown hidden">
    <div class="notification-dropdown__header">
        <h3>Notifications</h3>
        <button type="button" id="markAllNotificationsRead" class="mark-all-read-btn">Mark all as read</button>
    </div>
    
    <div class="notification-dropdown__content" id="notificationContent">
        <div class="notification-loading">
            <p>Loading notifications...</p>
        </div>
    </div>
    
    <div class="notification-dropdown__footer">
        <a href="{{ path('app_admin_notification_index') }}">View all notifications</a>
    </div>
</div>

