{% extends 'base.html.twig' %}

{% block title %}File: {{ file.name }} · {% if is_granted('ROLE_ADMIN') %}Admin{% else %}Staff{% endif %}{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/admin_staff.css') }}">
{% endblock %}

{% block body %}
    {% include 'admin_staff/_adminstaffheader.html.twig' with { active: 'files' } %}
    
    <div class="admin-container">
        <div class="admin-header">
            <div>
                <h1 class="admin-title" style="font-family: 'Montserrat', Arial, sans-serif;">{{ file.name }}</h1>
                <p class="admin-subtitle">File Details</p>
            </div>
            <div class="admin-toolbar">
                <a class="btn-secondary" href="{{ path('app_admin_file_index') }}">← Back to Files</a>
                <a href="{{ asset('uploads/' ~ file.path) }}" target="_blank" class="btn-icon" title="Download File">
                    <i class="bi bi-download"></i>
                </a>
                <button type="button" class="btn-icon btn-danger" onclick="deleteFile('{{ filePath|url_encode }}', '{{ file.name|e('js') }}', {{ file.inUse ? 'true' : 'false' }}, {{ file.references|length }})" title="Delete File">
                    <i class="bi bi-trash"></i>
                </button>
            </div>
        </div>

        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert {{ label == 'success' ? 'alert-success' : (label == 'error' ? 'alert-error' : '') }}">{{ message }}</div>
            {% endfor %}
        {% endfor %}

        <div class="admin-card" style="padding: 1.1rem 1.25rem; margin-bottom: 2rem;">
            <h2 style="font-family:'Poppins'; font-size:1.2rem; margin: 0 0 0.9rem 0;">File Information</h2>
            <div class="admin-table-wrapper">
                <table class="admin-table table-balanced table-colored">
                    <thead>
                        <tr>
                            <th class="col-title" style="font-family: 'Poppins', Arial, sans-serif;">Field</th>
                            <th class="col-category" style="font-family: 'Poppins', Arial, sans-serif;">Value</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr class="admin-row">
                            <td style="font-family: 'Poppins', Arial, sans-serif;"><strong>Name</strong></td>
                            <td style="font-family: 'Montserrat', Arial, sans-serif;">{{ file.name }}</td>
                        </tr>
                        <tr class="admin-row">
                            <td style="font-family: 'Poppins', Arial, sans-serif;"><strong>Type</strong></td>
                            <td>
                                <span class="badge-status {% if file.type == 'image' %}is-completed{% elseif file.type == 'document' %}is-ongoing{% else %}is-pending{% endif %}" style="text-transform: capitalize;">{{ file.type }}</span>
                                <span style="font-family: 'Montserrat', Arial, sans-serif; color: #6b7280; margin-left: 0.5rem;">({{ file.extension|upper }})</span>
                            </td>
                        </tr>
                        <tr class="admin-row">
                            <td style="font-family: 'Poppins', Arial, sans-serif;"><strong>Size</strong></td>
                            <td style="font-family: 'Montserrat', Arial, sans-serif;">{{ file.sizeFormatted }} ({{ file.size|number_format }} bytes)</td>
                        </tr>
                        <tr class="admin-row">
                            <td style="font-family: 'Poppins', Arial, sans-serif;"><strong>MIME Type</strong></td>
                            <td style="font-family: 'Montserrat', Arial, sans-serif;">{{ file.mimeType }}</td>
                        </tr>
                        <tr class="admin-row">
                            <td style="font-family: 'Poppins', Arial, sans-serif;"><strong>Path</strong></td>
                            <td style="font-family: 'Montserrat', Arial, sans-serif; font-size: 0.875rem; color: #6b7280;">
                                <code style="background: #f3f4f6; padding: 0.25rem 0.5rem; border-radius: 4px;">{{ file.path }}</code>
                            </td>
                        </tr>
                        <tr class="admin-row">
                            <td style="font-family: 'Poppins', Arial, sans-serif;"><strong>Status</strong></td>
                            <td>
                                {% if file.inUse %}
                                    <span class="badge-status is-ongoing" style="background: #fef3c7; color: #92400e; border: 1px solid #fde68a;">
                                        <i class="bi bi-exclamation-triangle-fill" style="margin-right: 0.25rem;"></i>In Use
                                    </span>
                                {% else %}
                                    <span class="badge-status is-pending" style="background: #f0fdf4; color: #166534; border: 1px solid #bbf7d0;">
                                        <i class="bi bi-check-circle-fill" style="margin-right: 0.25rem;"></i>Orphaned
                                    </span>
                                {% endif %}
                            </td>
                        </tr>
                        <tr class="admin-row">
                            <td style="font-family: 'Poppins', Arial, sans-serif;"><strong>References</strong></td>
                            <td style="font-family: 'Montserrat', Arial, sans-serif;">
                                {% if file.references|length > 0 %}
                                    <div style="display: flex; flex-direction: column; gap: 0.5rem;">
                                        {% for ref in file.references %}
                                            <div>
                                                <span style="color: #6b7280;">{{ ref.type }}:</span>
                                                <a href="{{ path('app_user_show', {'id': ref.entityId}) }}" class="btn-link" style="font-family: 'Poppins', Arial, sans-serif;">
                                                    {{ ref.entityName }}
                                                </a>
                                            </div>
                                        {% endfor %}
                                    </div>
                                    {% if file.lastUsed %}
                                        <div style="color: #9ca3af; font-size: 0.875rem; margin-top: 0.5rem;">
                                            Last used: {{ file.lastUsed|date('Y-m-d H:i:s') }}
                                        </div>
                                    {% endif %}
                                {% else %}
                                    <span style="color: #9ca3af;">No references</span>
                                {% endif %}
                            </td>
                        </tr>
                        <tr class="admin-row">
                            <td style="font-family: 'Poppins', Arial, sans-serif;"><strong>Last Modified</strong></td>
                            <td style="font-family: 'Montserrat', Arial, sans-serif;">{{ file.modified|date('Y-m-d H:i:s') }}</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        {% if file.type == 'image' %}
        <div class="admin-card" style="padding: 1.1rem 1.25rem; margin-bottom: 2rem;">
            <h2 style="font-family:'Poppins'; font-size:1.2rem; margin: 0 0 0.9rem 0;">Preview</h2>
            <div style="text-align: center; padding: 1rem; background: #f9fafb; border-radius: 8px;">
                <img src="{{ asset('uploads/' ~ file.path) }}" alt="{{ file.name }}" style="max-width: 100%; max-height: 500px; border-radius: 4px; box-shadow: 0 2px 8px rgba(0,0,0,0.1);">
            </div>
        </div>
        {% endif %}
    </div>

    <!-- Delete Confirmation Modal -->
    <div id="deleteFileModal" class="modal" style="display: none;">
        <div class="modal-content">
            <h3 style="font-family: 'Poppins', Arial, sans-serif; margin-bottom: 1rem;">Delete File</h3>
            <div id="deleteFileWarning" style="display: none; margin-bottom: 1rem; padding: 1rem; background: #fef3c7; border: 1px solid #fde68a; border-radius: 8px;">
                <div style="display: flex; align-items: start; gap: 0.75rem;">
                    <i class="bi bi-exclamation-triangle-fill" style="color: #d97706; font-size: 1.25rem; margin-top: 2px;"></i>
                    <div>
                        <div style="font-family: 'Poppins', Arial, sans-serif; font-size: 0.875rem; color: #92400e; font-weight: 600; margin-bottom: 0.25rem;">Warning: File is in use</div>
                        <div style="font-family: 'Montserrat', Arial, sans-serif; font-size: 0.8125rem; color: #78350f;" id="deleteFileWarningText"></div>
                    </div>
                </div>
            </div>
            <p style="font-family: 'Montserrat', Arial, sans-serif; margin-bottom: 1.5rem;">Are you sure you want to delete <strong id="deleteFileName"></strong>? This action cannot be undone.</p>
            <form id="deleteFileForm" method="POST" style="display: flex; gap: 0.5rem; justify-content: flex-end;">
                <input type="hidden" name="_token" value="{{ csrf_token('delete_file') }}">
                <button type="button" class="btn-secondary" onclick="closeDeleteModal()" style="padding: 0.5rem 1rem; font-family: 'Poppins', Arial, sans-serif;">Cancel</button>
                <button type="submit" class="btn-danger" style="padding: 0.5rem 1rem; font-family: 'Poppins', Arial, sans-serif;">Delete</button>
            </form>
        </div>
    </div>

    <!-- Deleting Modal -->
    <div id="deletingFileModal" class="modal" style="display: none;">
        <div class="modal-content">
            <div style="text-align: center; padding: 1rem;">
                <div style="margin-bottom: 1rem;">
                    <div class="spinner" style="border: 4px solid #f3f4f6; border-top: 4px solid var(--color-primary); border-radius: 50%; width: 48px; height: 48px; animation: spin 1s linear infinite; margin: 0 auto;"></div>
                </div>
                <h3 style="font-family: 'Poppins', Arial, sans-serif; margin-bottom: 0.5rem; color: #374151;">Deleting File...</h3>
                <p style="font-family: 'Montserrat', Arial, sans-serif; color: #6b7280; font-size: 0.875rem;">Please wait while we delete <strong id="deletingFileName"></strong></p>
            </div>
        </div>
    </div>

    <!-- Success Modal -->
    <div id="deleteSuccessModal" class="project-modal hidden" aria-hidden="true">
        <div class="project-modal__backdrop"></div>
        <div class="project-modal__dialog success-modal-dialog" role="dialog" aria-modal="true" aria-labelledby="deleteSuccessTitle" style="max-width: 380px;">
            <div class="success-modal-content">
                <div style="text-align: center; padding: 0.75rem 0 1.25rem;">
                    <div style="width: 60px; height: 60px; margin: 0 auto 0.75rem; background: #d1fae5; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                        <i class="bi bi-check-circle-fill" style="font-size: 2.25rem; color: #10b981;"></i>
                    </div>
                    <h2 id="deleteSuccessTitle" class="success-modal-title" style="font-family: 'Poppins', Arial, sans-serif; font-size: 1.25rem; font-weight: 600; color: #111827; margin-bottom: 0.5rem; text-align: center;">File Deleted Successfully!</h2>
                    <p class="success-modal-message" id="deleteSuccessMessage" style="font-family: 'Montserrat', Arial, sans-serif; color: #6b7280; font-size: 0.875rem; line-height: 1.5; text-align: center; margin-bottom: 1.25rem;">The file has been deleted successfully.</p>
                </div>
                <div class="success-modal-footer" style="display: flex; justify-content: center;">
                    <button type="button" class="btn btn-primary" onclick="closeSuccessModal()" style="min-width: 100px; padding: 0.5rem 1rem; font-size: 0.875rem;">
                        <span>Got it</span>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script>
        function deleteFile(path, fileName, inUse, referenceCount) {
            document.getElementById('deleteFileName').textContent = fileName;
            document.getElementById('deleteFileForm').action = '{{ path('app_admin_file_delete', {'path': '__PATH__'}) }}'.replace('__PATH__', path);
            
            // Show warning if file is in use
            const warningDiv = document.getElementById('deleteFileWarning');
            const warningText = document.getElementById('deleteFileWarningText');
            
            if (inUse && referenceCount > 0) {
                warningText.textContent = 'This file is currently being used by ' + referenceCount + ' reference(s). Deleting it may cause issues in the system.';
                warningDiv.style.display = 'block';
            } else {
                warningDiv.style.display = 'none';
            }
            
            document.getElementById('deleteFileModal').style.display = 'flex';
        }

        function closeDeleteModal() {
            document.getElementById('deleteFileModal').style.display = 'none';
        }

        // Close modal when clicking outside
        document.getElementById('deleteFileModal')?.addEventListener('click', function(e) {
            if (e.target === this) {
                closeDeleteModal();
            }
        });

        // Handle form submission
        document.getElementById('deleteFileForm')?.addEventListener('submit', function(e) {
            e.preventDefault();
            const form = this;
            const formData = new FormData(form);
            const fileName = document.getElementById('deleteFileName').textContent;
            
            // Close confirmation modal and show deleting modal
            closeDeleteModal();
            document.getElementById('deletingFileName').textContent = fileName;
            document.getElementById('deletingFileModal').style.display = 'flex';
            
            fetch(form.action, {
                method: 'POST',
                body: formData
            })
            .then(response => response.json())
            .then(data => {
                // Hide deleting modal
                document.getElementById('deletingFileModal').style.display = 'none';
                
                if (data.success) {
                    // Update success message if it includes user profile picture reset info
                    const successMessage = document.getElementById('deleteSuccessMessage');
                    if (data.message && data.message.includes('profile picture')) {
                        successMessage.textContent = data.message;
                    }
                    
                    // Show success modal
                    const successModal = document.getElementById('deleteSuccessModal');
                    if (successModal) {
                        successModal.classList.remove('hidden');
                        successModal.classList.remove('closing');
                        successModal.setAttribute('aria-hidden', 'false');
                        document.body.style.overflow = 'hidden';
                        successModal.style.display = 'flex';
                    }
                    
                    // Redirect after 1.5 seconds
                    setTimeout(function() {
                        window.location.href = '{{ path('app_admin_file_index') }}';
                    }, 1500);
                } else {
                    // Show error alert
                    alert('Error: ' + (data.message || 'Failed to delete file.'));
                }
            })
            .catch(error => {
                console.error('Error:', error);
                // Hide deleting modal
                document.getElementById('deletingFileModal').style.display = 'none';
                alert('An error occurred while deleting the file.');
            });
        });

        function closeSuccessModal() {
            const successModal = document.getElementById('deleteSuccessModal');
            if (successModal) {
                successModal.classList.add('closing');
                successModal.setAttribute('aria-hidden', 'true');
                document.body.style.overflow = '';
                
                setTimeout(function() {
                    successModal.classList.add('hidden');
                    successModal.classList.remove('closing');
                    successModal.style.display = '';
                    window.location.href = '{{ path('app_admin_file_index') }}';
                }, 250);
            }
        }
    </script>

{% endblock %}

{% block javascripts %}
    <script src="{{ asset('controllers/admin_staff.js') }}"></script>
{% endblock %}

