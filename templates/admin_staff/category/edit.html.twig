{% extends 'base.html.twig' %}

{% block title %}Edit Category · {% if is_granted('ROLE_ADMIN') %}Admin{% else %}Staff{% endif %}{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/admin_staff.css') }}">
{% endblock %}

{% block body %}
    {% include 'admin_staff/_adminstaffheader.html.twig' with { active: 'categories' } %}
    
    <div class="admin-container">
        <div class="admin-header">
            <div>
                <h1 class="admin-title">Edit Category</h1>
                <p class="admin-subtitle">Update details for this category</p>
            </div>
        </div>

        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert {{ label == 'success' ? 'alert-success' : (label == 'error' ? 'alert-error' : '') }}">{{ message }}</div>
            {% endfor %}
        {% endfor %}

        <div class="admin-card" style="padding:1rem;">
            {{ include('admin_staff/category/_form.html.twig', {'button_label': 'Update'}) }}
        </div>

        <div style="margin-top:1rem; display:flex; justify-content:flex-end;">
            {{ include('admin_staff/category/_delete_form.html.twig') }}
        </div>
    </div>
{% endblock %}

{% block javascripts %}
    <script src="{{ asset('controllers/admin_staff.js') }}"></script>
{% endblock %}
