{% extends 'base.html.twig' %}

{% block title %}Category Details · {% if is_granted('ROLE_ADMIN') %}Admin{% else %}Staff{% endif %}{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/admin_staff.css') }}">
{% endblock %}

{% block body %}
    {% include 'admin_staff/_adminstaffheader.html.twig' with { active: 'categories' } %}
    
    <div class="admin-container">
        <div class="admin-header">
            <div>
                <h1 class="admin-title">Category</h1>
                <p class="admin-subtitle">Details for this category</p>
            </div>
            <div class="admin-toolbar">
                <a class="btn-secondary" href="{{ path('app_category_index') }}">Back</a>
                <a class="btn-primary" href="{{ path('app_category_edit', {'id': category.id}) }}">Edit</a>
            </div>
        </div>

        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert {{ label == 'success' ? 'alert-success' : (label == 'error' ? 'alert-error' : '') }}">{{ message }}</div>
            {% endfor %}
        {% endfor %}

        <div class="admin-card" style="padding:1rem;">
            <table class="admin-table table-colored">
                <tbody>
                    <tr>
                        <th>Id</th>
                        <td>{{ category.id }}</td>
                    </tr>
                    <tr>
                        <th>Name</th>
                        <td>{{ category.name }}</td>
                    </tr>
                    <tr>
                        <th>Description</th>
                        <td>{{ category.description }}</td>
                    </tr>
                </tbody>
            </table>
        </div>

        <div style="margin-top:1rem; display:flex; justify-content:flex-end;">
            {{ include('admin_staff/category/_delete_form.html.twig') }}
        </div>
    </div>
{% endblock %}

{% block javascripts %}
    <script src="{{ asset('controllers/admin_staff.js') }}"></script>
{% endblock %}