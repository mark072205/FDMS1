                                                (status == 'pending' ? 'is-pending' : 'is-cancelled'))
                                            %}
                                            <span class="badge-status {{ statusClass }}">{{ project.status|capitalize }}</span>
                                        </div>
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                    {% else %}
                        <div class="empty-state">
                            <i class="bi bi-folder-x"></i>
                            <p>No recent projects found</p>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>

        <!-- Proposals Summary -->
        <div class="admin-card user-activity-summary" style="margin-bottom: 2rem;">
            <div class="activity-header">
                <h2 class="activity-title">
                    <i class="bi bi-file-earmark-text-fill"></i>
                    Proposals Summary
                </h2>
                <a href="{{ path('app_admin_proposal_index') }}" class="view-all-link">
                    View All Proposals
                    <i class="bi bi-arrow-right"></i>
                </a>
            </div>
            
            <!-- Proposals Stats Grid -->
            <div class="user-stats-grid">
                <div class="user-metric enhanced-metric">
                    <div class="metric-icon blue">
                        <i class="bi bi-file-earmark-text-fill"></i>
                    </div>
                    <div class="metric-content">
                        <div class="metric-value-row">
                            <p class="metric-value" style="font-weight: 400;">{{ totalProposals|default(0) }}</p>
                            <div class="metric-trend positive">
                                <i class="bi bi-arrow-up"></i>
                            </div>
                        </div>
                        <div class="metric-label">Total Proposals</div>
                        <div class="metric-subtitle">All time</div>
                    </div>
                </div>
                
                <div class="user-metric enhanced-metric">
                    <div class="metric-icon orange">
                        <i class="bi bi-clock-fill"></i>
                    </div>
                    <div class="metric-content">
                        <div class="metric-value-row">
                            <p class="metric-value" style="font-weight: 400;">{{ pendingProposals|default(0) }}</p>
                            <div class="metric-trend neutral">
                                <i class="bi bi-dash"></i>
                            </div>
                        </div>
                        <div class="metric-label">Pending</div>
                        <div class="metric-subtitle">Awaiting review</div>
                    </div>
                </div>
                
                <div class="user-metric enhanced-metric">
                    <div class="metric-icon green">
                        <i class="bi bi-check-circle-fill"></i>
                    </div>
                    <div class="metric-content">
                        <div class="metric-value-row">
                            <p class="metric-value" style="font-weight: 400;">{{ acceptedProposals|default(0) }}</p>
                            <div class="metric-trend positive">
                                <i class="bi bi-arrow-up"></i>
                            </div>
                        </div>
                        <div class="metric-label">Accepted</div>
                        <div class="metric-subtitle">Approved</div>
                    </div>
                </div>
                
                <div class="user-metric enhanced-metric">
                    <div class="metric-icon purple">
                        <i class="bi bi-x-circle-fill"></i>
                    </div>
                    <div class="metric-content">
                        <div class="metric-value-row">
                            <p class="metric-value" style="font-weight: 400;">{{ rejectedProposals|default(0) }}</p>
                            <div class="metric-trend negative">
                                <i class="bi bi-arrow-down"></i>
                            </div>
                        </div>
                        <div class="metric-label">Rejected</div>
                        <div class="metric-subtitle">Declined</div>
                    </div>
                </div>
            </div>

            <!-- Recent Proposals -->
            <div class="recent-logins-section">
                <div class="section-header">
                    <h3 class="section-title">
                        <i class="bi bi-clock-history"></i>
                        Recent Proposals
                    </h3>
                    <a href="{{ path('app_admin_proposal_index') }}" class="view-all-link">
                        View All Proposals
                        <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
                <div class="recent-logins-container">
                    {% if recentProposals|length > 0 %}
                        <div class="logins-list">
                            {% for proposal in recentProposals %}
                                <div class="login-item">
                                    <div class="user-avatar is-designer" style="width: 40px; height: 40px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1rem; color: #ffffff; font-weight: 400; font-family: 'Montserrat', Arial, sans-serif; background: #8b5cf6;">
                                        <i class="bi bi-file-earmark-text-fill"></i>
                                    </div>
                                    <div class="user-details">
                                        <div class="user-name">{{ proposal.project ? proposal.project.title : 'No Project' }}</div>
                                        <div class="user-role">{{ proposal.designer ? proposal.designer.username : 'No Designer' }} • ${{ proposal.proposedPrice|number_format(2, '.', ',') }}</div>
                                    </div>
                                    <div class="login-info">
                                        <div class="login-time">{{ proposal.createdAt|date('M d, Y') }}</div>
                                        <div class="login-status">
                                            {% set status = proposal.status|lower %}
                                            {% set statusClass =
                                                status == 'accepted' ? 'is-completed' :
                                                (status == 'rejected' ? 'is-cancelled' : 'is-pending')
                                            %}
                                            <span class="badge-status {{ statusClass }}">{{ proposal.status|capitalize }}</span>
                                        </div>
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                    {% else %}
                        <div class="empty-state">
                            <i class="bi bi-file-earmark-x"></i>
                            <p>No recent proposals found</p>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>

        <!-- Files Summary -->
        <div class="admin-card user-activity-summary" style="margin-bottom: 2rem;">
            <div class="activity-header">
                <h2 class="activity-title">
                    <i class="bi bi-file-earmark-fill"></i>
                    Files Overview
                </h2>
                <a href="{{ path('app_admin_file_index') }}" class="view-all-link">
                    View All Files
                    <i class="bi bi-arrow-right"></i>
                </a>
            </div>
            
            <!-- Files Stats Grid -->
            <div class="user-stats-grid">
                <div class="user-metric enhanced-metric">
                    <div class="metric-icon blue">
                        <i class="bi bi-file-earmark-fill"></i>
                    </div>
                    <div class="metric-content">
                        <div class="metric-value-row">
                            <p class="metric-value" style="font-weight: 400;">{{ totalFiles|default(0) }}</p>
                            <div class="metric-trend positive">
                                <i class="bi bi-arrow-up"></i>
                            </div>
                        </div>
                        <div class="metric-label">Total Files</div>
                        <div class="metric-subtitle">{{ totalFileSizeFormatted|default('0 B') }}</div>
                    </div>
                </div>
                
                <div class="user-metric enhanced-metric">
                    <div class="metric-icon green">
                        <i class="bi bi-image-fill"></i>
                    </div>
                    <div class="metric-content">
                        <div class="metric-value-row">
                            <p class="metric-value" style="font-weight: 400;">{{ imageFiles|default(0) }}</p>
                            <div class="metric-trend positive">
                                <i class="bi bi-arrow-up"></i>
                            </div>
                        </div>
                        <div class="metric-label">Images</div>
                        <div class="metric-subtitle">Photo files</div>
                    </div>
                </div>
                
                <div class="user-metric enhanced-metric">
                    <div class="metric-icon orange">
                        <i class="bi bi-file-text-fill"></i>
                    </div>
                    <div class="metric-content">
                        <div class="metric-value-row">
                            <p class="metric-value" style="font-weight: 400;">{{ documentFiles|default(0) }}</p>
                            <div class="metric-trend neutral">
                                <i class="bi bi-dash"></i>
                            </div>
                        </div>
                        <div class="metric-label">Documents</div>
                        <div class="metric-subtitle">PDF, DOC, etc.</div>
                    </div>
                </div>
                
                <div class="user-metric enhanced-metric">
                    <div class="metric-icon purple">
                        <i class="bi bi-check-circle-fill"></i>
                    </div>
                    <div class="metric-content">
                        <div class="metric-value-row">
                            <p class="metric-value" style="font-weight: 400;">{{ filesInUse|default(0) }}</p>
                            <div class="metric-trend positive">
                                <i class="bi bi-arrow-up"></i>
                            </div>
                        </div>
                        <div class="metric-label">In Use</div>
                        <div class="metric-subtitle">Referenced</div>
                    </div>
                </div>
            </div>

            <!-- Recent Files -->
            <div class="recent-logins-section">
                <div class="section-header">
                    <h3 class="section-title">
                        <i class="bi bi-clock-history"></i>
                        Recent Files
                    </h3>
                    <a href="{{ path('app_admin_file_index') }}" class="view-all-link">
                        View All Files
                        <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
                <div class="recent-logins-container">
                    {% if recentFiles|length > 0 %}
                        <div class="logins-list">
                            {% for file in recentFiles %}
                                <div class="login-item">
                                    <div class="user-avatar is-client" style="width: 40px; height: 40px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1rem; color: #ffffff; font-weight: 400; font-family: 'Montserrat', Arial, sans-serif; background: {% if file.type == 'image' %}#10b981{% elseif file.type == 'document' %}#f59e0b{% else %}#6366f1{% endif %};">
                                        {% if file.type == 'image' %}
                                            <i class="bi bi-image-fill"></i>
                                        {% elseif file.type == 'document' %}
                                            <i class="bi bi-file-text-fill"></i>
                                        {% else %}
                                            <i class="bi bi-file-earmark-fill"></i>
                                        {% endif %}
                                    </div>
                                    <div class="user-details">
                                        <div class="user-name">{{ file.filename }}</div>
                                        <div class="user-role">{{ file.type|capitalize }} • {{ file.sizeFormatted }}</div>
                                    </div>
                                    <div class="login-info">
                                        <div class="login-time">{{ file.uploadedAt|date('M d, Y') }}</div>
                                        <div class="login-status">
                                            {% if file.usageCount > 0 %}
                                                <span class="badge-status is-ongoing">In Use</span>
                                            {% else %}
                                                <span class="badge-status is-pending">Orphaned</span>
                                            {% endif %}
                                        </div>
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                    {% else %}
                        <div class="empty-state">
                            <i class="bi bi-file-earmark-x"></i>
                            <p>No recent files found</p>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>

        <!-- User Activity Summary -->
        {% if not (is_granted('ROLE_STAFF') and not is_granted('ROLE_ADMIN')) %}
        <div class="admin-card user-activity-summary" style="margin-bottom: 2rem;">
            <div class="activity-header">
                <h2 class="activity-title">
                    <i class="bi bi-activity"></i>
                    User Activity Summary
                </h2>
                <div class="activity-period">
                    <span class="period-label">Last 7 days</span>
                </div>
            </div>
            
            <!-- Enhanced User Stats Grid -->
            <div class="user-stats-grid">
                <div class="user-metric enhanced-metric">
                    <div class="metric-icon blue">
                        <i class="bi bi-person-check-fill"></i>
                    </div>
                    <div class="metric-content">
                        <div class="metric-value-row">
                            <p class="metric-value" style="font-weight: 400;">{{ activeUsers }}</p>
                            <div class="metric-trend positive">
                                <i class="bi bi-arrow-up"></i>
                            </div>
                        </div>
                        <div class="metric-label">Active Users</div>
                        <div class="metric-subtitle">Last 7 days</div>
                    </div>
                </div>
                
                <div class="user-metric enhanced-metric">
                    <div class="metric-icon orange">
                        <i class="bi bi-clock-fill"></i>
                    </div>
                    <div class="metric-content">
                        <div class="metric-value-row">
                            <p class="metric-value" style="font-weight: 400;">{{ pendingVerifications }}</p>
                            <div class="metric-trend negative">
                                <i class="bi bi-arrow-down"></i>
                            </div>
                        </div>
                        <div class="metric-label">Pending</div>
                        <div class="metric-subtitle">Awaiting email verification</div>
                    </div>
                </div>
                
                <div class="user-metric enhanced-metric">
                    <div class="metric-icon green">
                        <i class="bi bi-people-fill"></i>
                    </div>
                    <div class="metric-content">
                        <div class="metric-value-row">
                            <p class="metric-value" style="font-weight: 400;">{{ totalUsers }}</p>
                            <div class="metric-trend positive">
                                <i class="bi bi-arrow-up"></i>
                            </div>
                        </div>
                        <div class="metric-label">Total Users</div>
                        <div class="metric-subtitle">All time (Admin: {{ totalAdmins|default(0) }}, Staff: {{ totalStaff|default(0) }})</div>
                    </div>
                </div>
                
                <div class="user-metric enhanced-metric">
                    <div class="metric-icon purple">
                        <i class="bi bi-calendar-check-fill"></i>
                    </div>
                    <div class="metric-content">
                        <div class="metric-value-row">
                            <p class="metric-value" style="font-weight: 400;">{{ recentLogins|length }}</p>
                            <div class="metric-trend positive">
                                <i class="bi bi-arrow-up"></i>
                            </div>
                        </div>
                        <div class="metric-label">Recent Logins</div>
                        <div class="metric-subtitle">Today</div>
                    </div>
                </div>
            </div>

            <!-- Enhanced User Role Distribution -->
            <div class="role-distribution-section">
                <div class="section-header">
                    <h3 class="section-title">
                        <i class="bi bi-diagram-3-fill"></i>
                        User Role Distribution
                    </h3>
                    <div class="role-summary">
                        <span class="total-roles">{{ usersByRole|length }} roles</span>
                    </div>
                </div>
                <div class="role-distribution-grid">
                    {% for roleData in usersByRole %}
                        <div class="role-card">
                            <div class="role-icon">
                                {% if roleData.role|lower == 'designer' %}
                                    <i class="bi bi-palette-fill"></i>
                                {% elseif roleData.role|lower == 'client' %}
                                    <i class="bi bi-person-badge-fill"></i>
                                {% else %}
                                    <i class="bi bi-person-fill"></i>
                                {% endif %}
                            </div>
                            <div class="role-info">
                                <span class="role-name">{{ roleData.role|capitalize }}</span>
                                <span class="role-count">{{ roleData.count }} users</span>
                            </div>
                            <div class="role-percentage">
                                {{ ((roleData.count / totalUsers) * 100)|round(1) }}%
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </div>

            <!-- Enhanced Recent Logins -->
            <div class="recent-logins-section">
                <div class="section-header">
                    <h3 class="section-title">
                        <i class="bi bi-clock-history"></i>
                        Recent Activity
                    </h3>
                    <a href="{{ path('app_user_index') }}" class="view-all-link">
                        View All Users
                        <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
                <div class="recent-logins-container">
                    {% if recentLogins|length > 0 %}
                        <div class="logins-list">
                            {% for user in recentLogins %}
                                <div class="login-item">
                                    {% set roleType = (user.userType is defined and user.userType ? user.userType : (user.role is defined ? user.role : 'admin'))|lower %}
                                    <div class="user-avatar {{ roleType == 'designer' ? 'is-designer' : (roleType == 'client' ? 'is-client' : (roleType == 'staff' ? 'is-staff' : 'is-admin')) }}" style="width: 40px; height: 40px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1rem; color: #ffffff; font-weight: 400; font-family: 'Montserrat', Arial, sans-serif;">
                                        {% if user.profilePicture %}
                                            <img src="{{ asset('uploads/profile_pictures/' ~ user.profilePicture) }}" alt="{{ user.username }}" style="width: 100%; height: 100%; border-radius: 50%; object-fit: cover;">
                                        {% else %}
                                            <span class="avatar-text">{{ user.firstName|first|upper }}{{ user.lastName|first|upper }}</span>
                                        {% endif %}
                                    </div>
                                    <div class="user-details">
                                        <div class="user-name">{{ user.username }}</div>
                                        <div class="user-role">{{ user.role|capitalize }}</div>
                                    </div>
                                    <div class="login-info">
                                        <div class="login-time">{{ user.lastLogin|date('M d, H:i') }}</div>
                                        <div class="login-status">
                                            {% if user.userType == 'admin' or user.userType == 'staff' %}
                                                <span class="status-badge verified">
                                                    <i class="bi bi-check-circle-fill"></i>
                                                    Verified
                                                </span>
                                            {% elseif user.verified %}
                                                <span class="status-badge verified">
                                                    <i class="bi bi-check-circle-fill"></i>
                                                    Verified
                                                </span>
                                            {% else %}
                                                <span class="status-badge pending">
                                                    <i class="bi bi-clock-fill"></i>
                                                    Pending
                                                </span>
                                            {% endif %}
                                        </div>
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                    {% else %}
                        <div class="empty-state">
                            <i class="bi bi-person-x"></i>
                            <p>No recent activity found</p>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
        {% endif %}


    </div>

    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            {% if is_granted('ROLE_ADMIN') %}
            const timeSeries = {{ analytics.timeSeries|json_encode|raw }};

            // Revenue Trend Chart
            const revenueCtx = document.getElementById('dashboardRevenueChart');
            if (revenueCtx) {
                new Chart(revenueCtx, {
                    type: 'line',
                    data: {
                        labels: timeSeries.labels,
                        datasets: [{
                            label: 'Revenue',
                            data: timeSeries.revenue,
                            borderColor: '#1e3a8a',
                            backgroundColor: 'rgba(30, 58, 138, 0.1)',
                            tension: 0.4,
                            fill: true
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: {
                                display: false
                            }
                        },
                        scales: {
                            y: {
                                beginAtZero: true,
                                ticks: {
                                    callback: function(value) {
                                        return '$' + value.toLocaleString();
                                    }
                                }
                            }
                        }
                    }
                });
            }

            // User Growth Chart
            const userGrowthCtx = document.getElementById('dashboardUserGrowthChart');
            if (userGrowthCtx) {
                new Chart(userGrowthCtx, {
                    type: 'bar',
                    data: {
                        labels: timeSeries.labels,
                        datasets: [{
                            label: 'New Users',
                            data: timeSeries.users,
                            backgroundColor: '#0d9488',
                            borderColor: '#0d9488',
                            borderWidth: 1
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: {
                                display: false
                            }
                        },
                        scales: {
                            y: {
                                beginAtZero: true,
                                ticks: {
                                    stepSize: 1
                                }
                            }
                        }
                    }
                });
            }
            {% endif %}
        });
    </script>
</body>
</html>