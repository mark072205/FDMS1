{% extends 'base.html.twig' %}

{% block title %}Proposal #{{ proposal.id }} - Proposal Details · {% if is_granted('ROLE_ADMIN') %}Admin{% else %}Staff{% endif %}{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/admin_staff.css') }}">
{% endblock %}

{% block body %}
    {% include 'admin_staff/_adminstaffheader.html.twig' with { active: 'proposals' } %}
    
    <div class="admin-container">
        <div class="admin-header">
            <div>
                <h1 class="admin-title">Proposal #{{ proposal.id }}</h1>
                <p class="admin-subtitle">Proposal Details</p>
            </div>
            <div class="admin-toolbar">
                <a class="btn-secondary" href="{{ path('app_admin_proposal_index') }}">← Back to Proposals</a>
                {% if is_granted('ROLE_ADMIN') or is_granted('ROLE_STAFF') %}
                    <button type="button" class="btn-danger btn-delete-proposal" 
                            data-proposal-id="{{ proposal.id }}"
                            data-proposal-project="{{ proposal.project.title }}"
                            data-proposal-designer="{{ proposal.designer.username }}"
                            title="Delete Proposal">
                        <i class="bi bi-trash"></i> Delete Proposal
                    </button>
                {% endif %}
            </div>
        </div>

        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert {{ label == 'success' ? 'alert-success' : (label == 'error' ? 'alert-error' : '') }}">{{ message }}</div>
            {% endfor %}
        {% endfor %}

        <div class="admin-card" style="padding: 1.1rem 1.25rem; margin-bottom: 2rem;">
            <h2 style="font-family:'Poppins'; font-size:1.2rem; margin: 0 0 0.9rem 0;">Proposal Information</h2>
            <div class="admin-table-wrapper">
                <table class="admin-table table-balanced table-colored">
                    <thead>
                        <tr>
                            <th class="col-title" style="font-family: 'Poppins', Arial, sans-serif;">Field</th>
                            <th class="col-category" style="font-family: 'Poppins', Arial, sans-serif;">Value</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr class="admin-row">
                            <td style="font-family: 'Poppins', Arial, sans-serif;"><strong>ID</strong></td>
                            <td style="font-family: 'Montserrat', Arial, sans-serif;">{{ proposal.id }}</td>
                        </tr>
                        <tr class="admin-row">
                            <td style="font-family: 'Poppins', Arial, sans-serif;"><strong>Project</strong></td>
                            <td style="font-family: 'Montserrat', Arial, sans-serif;">
                                <a href="{{ path('app_admin_project_show', {'id': proposal.project.id}) }}" class="btn-link" style="font-family: 'Poppins', Arial, sans-serif;">
                                    {{ proposal.project.title }}
                                </a>
                            </td>
                        </tr>
                        <tr class="admin-row">
                            <td style="font-family: 'Poppins', Arial, sans-serif;"><strong>Designer</strong></td>
                            <td style="font-family: 'Montserrat', Arial, sans-serif;">
                                <a href="{{ path('app_user_show', {'id': proposal.designer.id}) }}" class="btn-link" style="font-family: 'Poppins', Arial, sans-serif;">
                                    {{ proposal.designer.username }} ({{ proposal.designer.firstName }} {{ proposal.designer.lastName }})
                                </a>
                            </td>
                        </tr>
                        <tr class="admin-row">
                            <td style="font-family: 'Poppins', Arial, sans-serif;"><strong>Status</strong></td>
                            <td>
                                {% set status = proposal.status|lower %}
                                {% set statusClass =
                                    status == 'accepted' ? 'is-completed' :
                                    (status == 'rejected' ? 'is-cancelled' : 'is-pending')
                                %}
                                <span class="badge-status {{ statusClass }}">{{ proposal.status|capitalize }}</span>
                            </td>
                        </tr>
                        <tr class="admin-row">
                            <td style="font-family: 'Poppins', Arial, sans-serif;"><strong>Proposed Price</strong></td>
                            <td style="font-family: 'Montserrat', Arial, sans-serif;">${{ proposal.proposedPrice|number_format(2, '.', ',') }}</td>
                        </tr>
                        <tr class="admin-row">
                            <td style="font-family: 'Poppins', Arial, sans-serif;"><strong>Delivery Time</strong></td>
                            <td style="font-family: 'Montserrat', Arial, sans-serif;">{{ proposal.deliveryTime }} days</td>
                        </tr>
                        <tr class="admin-row">
                            <td style="font-family: 'Poppins', Arial, sans-serif;"><strong>Revision Rounds</strong></td>
                            <td style="font-family: 'Montserrat', Arial, sans-serif;">{{ proposal.revisionRounds }}</td>
                        </tr>
                        <tr class="admin-row">
                            <td style="font-family: 'Poppins', Arial, sans-serif;"><strong>Created At</strong></td>
                            <td style="font-family: 'Montserrat', Arial, sans-serif;">{{ proposal.createdAt|date('Y-m-d H:i:s') }}</td>
                        </tr>
                        {% if proposal.updatedAt %}
                        <tr class="admin-row">
                            <td style="font-family: 'Poppins', Arial, sans-serif;"><strong>Updated At</strong></td>
                            <td style="font-family: 'Montserrat', Arial, sans-serif;">{{ proposal.updatedAt|date('Y-m-d H:i:s') }}</td>
                        </tr>
                        {% endif %}
                        {% if proposal.respondedAt %}
                        <tr class="admin-row">
                            <td style="font-family: 'Poppins', Arial, sans-serif;"><strong>Responded At</strong></td>
                            <td style="font-family: 'Montserrat', Arial, sans-serif;">{{ proposal.respondedAt|date('Y-m-d H:i:s') }}</td>
                        </tr>
                        {% endif %}
                    </tbody>
                </table>
            </div>
        </div>

        {% if proposal.coverLetter %}
        <div class="admin-card" style="padding: 1.1rem 1.25rem; margin-bottom: 2rem;">
            <h2 style="font-family:'Poppins'; font-size:1.2rem; margin: 0 0 0.9rem 0;">Cover Letter</h2>
            <div style="font-family: 'Montserrat', Arial, sans-serif; color: #374151; line-height: 1.6; white-space: pre-wrap;">{{ proposal.coverLetter }}</div>
        </div>
        {% endif %}

        <div class="admin-card" style="padding: 1.1rem 1.25rem; margin-bottom: 2rem;">
            <h2 style="font-family:'Poppins'; font-size:1.2rem; margin: 0 0 0.9rem 0;">Proposal Text</h2>
            <div style="font-family: 'Montserrat', Arial, sans-serif; color: #374151; line-height: 1.6; white-space: pre-wrap;">{{ proposal.proposalText }}</div>
        </div>

        {% if proposal.rejectionReason %}
        <div class="admin-card" style="padding: 1.1rem 1.25rem; margin-bottom: 2rem; background: #fef2f2; border: 1px solid #fecaca;">
            <h2 style="font-family:'Poppins'; font-size:1.2rem; margin: 0 0 0.9rem 0; color: #991b1b;">Rejection Reason</h2>
            <div style="font-family: 'Montserrat', Arial, sans-serif; color: #991b1b; line-height: 1.6; white-space: pre-wrap;">{{ proposal.rejectionReason }}</div>
        </div>
        {% endif %}

        {% if proposal.clientNotes %}
        <div class="admin-card" style="padding: 1.1rem 1.25rem; margin-bottom: 2rem;">
            <h2 style="font-family:'Poppins'; font-size:1.2rem; margin: 0 0 0.9rem 0;">Client Notes</h2>
            <div style="font-family: 'Montserrat', Arial, sans-serif; color: #374151; line-height: 1.6; white-space: pre-wrap;">{{ proposal.clientNotes }}</div>
        </div>
        {% endif %}
    </div>
{% endblock %}

{% block javascripts %}
    <script src="{{ asset('controllers/admin_staff.js') }}"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const deleteBtn = document.querySelector('.btn-delete-proposal');
            if (deleteBtn) {
                deleteBtn.addEventListener('click', function(e) {
                    e.preventDefault();
                    
                    const proposalId = this.dataset.proposalId;
                    const projectTitle = this.dataset.proposalProject;
                    const designerName = this.dataset.proposalDesigner;
                    
                    if (window.adminManager && window.adminManager.showConfirmationModal) {
                        window.adminManager.showConfirmationModal(
                            `Are you sure you want to delete proposal #${proposalId} for project "${projectTitle}" by ${designerName}? This action cannot be undone.`,
                            function() {
                                // Disable button during deletion
                                deleteBtn.disabled = true;
                                deleteBtn.innerHTML = '<i class="bi bi-hourglass-split"></i> Deleting...';
                                
                                fetch(`/proposals/${proposalId}/delete`, {
                                    method: 'POST',
                                    headers: {
                                        'Content-Type': 'application/json',
                                        'X-Requested-With': 'XMLHttpRequest'
                                    }
                                })
                                .then(response => response.json())
                                .then(data => {
                                    if (data.success) {
                                        // Show success message
                                        if (window.adminManager && window.adminManager.showAlert) {
                                            window.adminManager.showAlert('success', data.message);
                                        } else {
                                            alert(data.message);
                                        }
                                        
                                        // Redirect to proposals index after a short delay
                                        setTimeout(() => {
                                            window.location.href = '{{ path('app_admin_proposal_index') }}';
                                        }, 1000);
                                    } else {
                                        // Show error message
                                        if (window.adminManager && window.adminManager.showAlert) {
                                            window.adminManager.showAlert('error', data.message);
                                        } else {
                                            alert('Error: ' + data.message);
                                        }
                                        
                                        // Re-enable button
                                        deleteBtn.disabled = false;
                                        deleteBtn.innerHTML = '<i class="bi bi-trash"></i> Delete Proposal';
                                    }
                                })
                                .catch(error => {
                                    console.error('Error:', error);
                                    if (window.adminManager && window.adminManager.showAlert) {
                                        window.adminManager.showAlert('error', 'An error occurred while deleting the proposal.');
                                    } else {
                                        alert('An error occurred while deleting the proposal.');
                                    }
                                    
                                    // Re-enable button
                                    deleteBtn.disabled = false;
                                    deleteBtn.innerHTML = '<i class="bi bi-trash"></i> Delete Proposal';
                                });
                            },
                            'danger',
                            'Delete Proposal'
                        );
                    } else {
                        // Fallback to browser confirm if adminManager is not available
                        if (confirm(`Are you sure you want to delete proposal #${proposalId} for project "${projectTitle}" by ${designerName}? This action cannot be undone.`)) {
                            // Disable button during deletion
                            deleteBtn.disabled = true;
                            deleteBtn.innerHTML = '<i class="bi bi-hourglass-split"></i> Deleting...';
                            
                            fetch(`/proposals/${proposalId}/delete`, {
                                method: 'POST',
                                headers: {
                                    'Content-Type': 'application/json',
                                    'X-Requested-With': 'XMLHttpRequest'
                                }
                            })
                            .then(response => response.json())
                            .then(data => {
                                if (data.success) {
                                    alert(data.message);
                                    window.location.href = '{{ path('app_admin_proposal_index') }}';
                                } else {
                                    alert('Error: ' + data.message);
                                    deleteBtn.disabled = false;
                                    deleteBtn.innerHTML = '<i class="bi bi-trash"></i> Delete Proposal';
                                }
                            })
                            .catch(error => {
                                console.error('Error:', error);
                                alert('An error occurred while deleting the proposal.');
                                deleteBtn.disabled = false;
                                deleteBtn.innerHTML = '<i class="bi bi-trash"></i> Delete Proposal';
                            });
                        }
                    }
                });
            }
        });
    </script>
{% endblock %}

