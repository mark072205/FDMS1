{% extends 'base.html.twig' %}

{% block title %}{{ project.title }} - Project Details · {% if is_granted('ROLE_ADMIN') %}Admin{% else %}Staff{% endif %}{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/admin_staff.css') }}">
{% endblock %}

{% block body %}
    {% include 'admin_staff/_adminstaffheader.html.twig' with { active: 'projects' } %}
    
    <div class="admin-container">
        <div class="admin-header">
            <div>
                <h1 class="admin-title">{{ project.title }}</h1>
                <p class="admin-subtitle">Project Details</p>
            </div>
            <div class="admin-toolbar">
                <a class="btn-secondary" href="{{ path('app_admin_project_index') }}">← Back to Projects</a>
                <form method="POST" action="{{ path('app_admin_project_delete', {'id': project.id}) }}" id="deleteProjectForm" style="display: inline;">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ project.id) }}">
                <button type="button" class="btn-danger" id="deleteProjectBtn" style="padding: 0.5rem 1rem; border: none; border-radius: 6px; cursor: pointer; font-family: 'Poppins', Arial, sans-serif;">
                    <i class="bi bi-trash"></i> Delete Project
                </button>
                </form>
            </div>
        </div>

        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert {{ label == 'success' ? 'alert-success' : (label == 'error' ? 'alert-error' : '') }}">{{ message }}</div>
            {% endfor %}
        {% endfor %}

        <div class="admin-card" style="padding: 1.1rem 1.25rem; margin-bottom: 2rem;">
            <h2 style="font-family:'Poppins'; font-size:1.2rem; margin: 0 0 0.9rem 0;">Project Information</h2>
            <div class="admin-table-wrapper">
                <table class="admin-table table-balanced table-colored">
                    <thead>
                        <tr>
                            <th class="col-title" style="font-family: 'Poppins', Arial, sans-serif;">Field</th>
                            <th class="col-category" style="font-family: 'Poppins', Arial, sans-serif;">Value</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr class="admin-row">
                            <td style="font-family: 'Poppins', Arial, sans-serif;"><strong>ID</strong></td>
                            <td style="font-family: 'Montserrat', Arial, sans-serif;">{{ project.id }}</td>
                        </tr>
                        <tr class="admin-row">
                            <td style="font-family: 'Poppins', Arial, sans-serif;"><strong>Title</strong></td>
                            <td style="font-family: 'Montserrat', Arial, sans-serif;">{{ project.title }}</td>
                        </tr>
                        <tr class="admin-row">
                            <td style="font-family: 'Poppins', Arial, sans-serif;"><strong>Description</strong></td>
                            <td style="font-family: 'Montserrat', Arial, sans-serif;">{{ project.description }}</td>
                        </tr>
                        <tr class="admin-row">
                            <td style="font-family: 'Poppins', Arial, sans-serif;"><strong>Status</strong></td>
                            <td>
                                {% set status = project.status|lower %}
                                {% set statusClass =
                                    status == 'completed' ? 'is-completed' :
                                    (status == 'ongoing' ? 'is-ongoing' :
                                    (status == 'pending' ? 'is-pending' : 'is-cancelled'))
                                %}
                                <span class="badge-status {{ statusClass }}">{{ project.status|capitalize }}</span>
                            </td>
                        </tr>
                        <tr class="admin-row">
                            <td style="font-family: 'Poppins', Arial, sans-serif;"><strong>Category</strong></td>
                            <td style="font-family: 'Montserrat', Arial, sans-serif;">{{ project.category ? project.category.name : '—' }}</td>
                        </tr>
                        <tr class="admin-row">
                            <td style="font-family: 'Poppins', Arial, sans-serif;"><strong>Client</strong></td>
                            <td style="font-family: 'Montserrat', Arial, sans-serif;">
                                {% if project.client %}
                                    <a href="{{ path('app_user_show', {'id': project.client.id}) }}" class="btn-link" style="font-family: 'Poppins', Arial, sans-serif;">
                                        {{ project.client.username }} ({{ project.client.firstName }} {{ project.client.lastName }})
                                    </a>
                                {% else %}
                                    —
                                {% endif %}
                            </td>
                        </tr>
                        <tr class="admin-row">
                            <td style="font-family: 'Poppins', Arial, sans-serif;"><strong>Budget</strong></td>
                            <td style="font-family: 'Montserrat', Arial, sans-serif;">${{ project.budget|number_format(2, '.', ',') }}</td>
                        </tr>
                        <tr class="admin-row">
                            <td style="font-family: 'Poppins', Arial, sans-serif;"><strong>Proposals Count</strong></td>
                            <td style="font-family: 'Montserrat', Arial, sans-serif;">{{ proposalsCount }}</td>
                        </tr>
                        <tr class="admin-row">
                            <td style="font-family: 'Poppins', Arial, sans-serif;"><strong>Created At</strong></td>
                            <td style="font-family: 'Montserrat', Arial, sans-serif;">{{ project.createdAt|date('Y-m-d H:i:s') }}</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>


        {% if proposalsCount > 0 %}
        <div class="admin-card" style="padding: 1.1rem 1.25rem; margin-bottom: 2rem;">
            <h2 style="font-family:'Poppins'; font-size:1.2rem; margin: 0 0 0.9rem 0;">Proposals ({{ proposalsCount }})</h2>
            <div class="admin-table-wrapper">
                <table class="admin-table table-balanced table-colored">
                    <thead>
                        <tr>
                            <th class="col-id" style="font-family: 'Poppins', Arial, sans-serif;">ID</th>
                            <th class="col-title" style="font-family: 'Poppins', Arial, sans-serif;">Designer</th>
                            <th class="col-category" style="font-family: 'Poppins', Arial, sans-serif;">Proposed Price</th>
                            <th class="col-status" style="font-family: 'Poppins', Arial, sans-serif;">Status</th>
                            <th class="col-date" style="font-family: 'Poppins', Arial, sans-serif;">Created</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for proposal in project.proposals %}
                            <tr class="admin-row">
                                <td style="font-family: 'Montserrat', Arial, sans-serif;">{{ proposal.id }}</td>
                                <td style="font-family: 'Montserrat', Arial, sans-serif;">
                                    {% if proposal.designer %}
                                        <a href="{{ path('app_user_show', {'id': proposal.designer.id}) }}" class="btn-link" style="font-family: 'Poppins', Arial, sans-serif;">
                                            {{ proposal.designer.username }}
                                        </a>
                                    {% else %}
                                        —
                                    {% endif %}
                                </td>
                                <td style="font-family: 'Montserrat', Arial, sans-serif;">${{ proposal.proposedPrice|number_format(2, '.', ',') }}</td>
                                <td>
                                    {% set proposalStatus = proposal.status|lower %}
                                    {% set proposalStatusClass =
                                        proposalStatus == 'accepted' ? 'is-completed' :
                                        (proposalStatus == 'rejected' ? 'is-cancelled' : 'is-pending')
                                    %}
                                    <span class="badge-status {{ proposalStatusClass }}">{{ proposal.status|capitalize }}</span>
                                </td>
                                <td style="font-family: 'Montserrat', Arial, sans-serif;">{{ proposal.createdAt|date('Y-m-d') }}</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
        {% endif %}
    </div>

{% endblock %}

{% block javascripts %}
    <script src="{{ asset('controllers/admin_staff.js') }}"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const deleteBtn = document.getElementById('deleteProjectBtn');
            const deleteForm = document.getElementById('deleteProjectForm');
            const proposalsCount = {{ proposalsCount ?? 0 }};
            
            if (deleteBtn && deleteForm) {
                deleteBtn.addEventListener('click', function(e) {
                    e.preventDefault();
                    
                    // Check if project has proposals
                    if (proposalsCount > 0) {
                        // Show error modal instead of confirmation
                        if (window.adminManager && window.adminManager.showConfirmationModal) {
                            const modal = document.getElementById('confirmationModal');
                            const modalMessage = document.getElementById('modalMessage');
                            const modalTitle = document.getElementById('modalTitle');
                            const confirmBtn = document.getElementById('modalConfirmBtn');
                            
                            if (modal && modalMessage && modalTitle && confirmBtn) {
                                modalTitle.textContent = 'Deletion Failed';
                                modalMessage.innerHTML = `Cannot delete this project. This project has <strong>${proposalsCount}</strong> associated proposal(s). Please delete the proposals first before deleting the project.`;
                                confirmBtn.className = 'btn btn-warning';
                                confirmBtn.style.display = 'flex';
                                confirmBtn.style.alignItems = 'center';
                                confirmBtn.style.justifyContent = 'center';
                                confirmBtn.style.gap = '0.5rem';
                                confirmBtn.innerHTML = '<span>OK</span>';
                                
                                // Remove existing listeners and add new one that just closes
                                const newConfirmBtn = confirmBtn.cloneNode(true);
                                confirmBtn.parentNode.replaceChild(newConfirmBtn, confirmBtn);
                                document.getElementById('modalConfirmBtn').addEventListener('click', () => {
                                    if (window.adminManager && window.adminManager.closeConfirmationModal) {
                                        window.adminManager.closeConfirmationModal();
                                    }
                                });
                                
                                modal.style.display = 'flex';
                            } else {
                                alert(`Cannot delete this project. This project has ${proposalsCount} associated proposal(s). Please delete the proposals first.`);
                            }
                        } else {
                            alert(`Cannot delete this project. This project has ${proposalsCount} associated proposal(s). Please delete the proposals first.`);
                        }
                        return;
                    }
                    
                    // No proposals - proceed with normal deletion confirmation
                    if (window.adminManager && window.adminManager.showConfirmationModal) {
                        window.adminManager.showConfirmationModal(
                            'Are you sure you want to delete this project? This action cannot be undone.',
                            function() {
                                deleteForm.submit();
                            },
                            'danger',
                            'Delete Project'
                        );
                    } else {
                        // Fallback to browser confirm if adminManager is not available
                        if (confirm('Are you sure you want to delete this project? This action cannot be undone.')) {
                            deleteForm.submit();
                        }
                    }
                });
            }
        });
    </script>
{% endblock %}

