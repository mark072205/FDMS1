<script>
document.addEventListener('DOMContentLoaded', function() {
    // Messages menu dropdown
    const menuBtn = document.querySelector('.messages-menu-btn');
    const menuDropdown = document.querySelector('.messages-menu-dropdown');
    
    if (menuBtn && menuDropdown) {
        // Toggle dropdown on button click
        menuBtn.addEventListener('click', function(e) {
            e.stopPropagation();
            const isExpanded = menuBtn.getAttribute('aria-expanded') === 'true';
            menuBtn.setAttribute('aria-expanded', !isExpanded);
        });
        
        // Close dropdown when clicking outside
        document.addEventListener('click', function(e) {
            if (!menuBtn.contains(e.target) && !menuDropdown.contains(e.target)) {
                menuBtn.setAttribute('aria-expanded', 'false');
            }
        });
        
        // Close dropdown when clicking on a menu item
        const menuItems = menuDropdown.querySelectorAll('.messages-menu-item');
        menuItems.forEach(function(item) {
            item.addEventListener('click', function(e) {
                e.preventDefault();
                menuBtn.setAttribute('aria-expanded', 'false');
                // TODO: Add functionality for each menu item
                console.log('Menu item clicked:', this.textContent.trim());
            });
        });
    }
    
    // Filter dropdown
    const filterBtn = document.querySelector('.messages-filter-btn');
    const filterDropdown = document.querySelector('.messages-filter-dropdown');
    
    if (filterBtn && filterDropdown) {
        // Toggle dropdown on button click
        filterBtn.addEventListener('click', function(e) {
            e.stopPropagation();
            const isExpanded = filterBtn.getAttribute('aria-expanded') === 'true';
            filterBtn.setAttribute('aria-expanded', !isExpanded);
        });
        
        // Close dropdown when clicking outside
        document.addEventListener('click', function(e) {
            if (!filterBtn.contains(e.target) && !filterDropdown.contains(e.target)) {
                filterBtn.setAttribute('aria-expanded', 'false');
            }
        });
        
        // Handle filter option clicks
        const filterOptions = filterDropdown.querySelectorAll('.messages-filter-option');
        filterOptions.forEach(function(option) {
            option.addEventListener('click', function(e) {
                e.preventDefault();
                // Remove active class from all options
                filterOptions.forEach(function(opt) {
                    opt.classList.remove('active');
                });
                // Add active class to clicked option
                this.classList.add('active');
                // TODO: Apply filter functionality
                console.log('Filter selected:', this.querySelector('span').textContent.trim());
            });
        });
    }
});
</script>
