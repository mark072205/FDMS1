<!-- Edit Project Modal Content -->
<div class="project-modal-content">
    <h2 class="project-modal__title">Edit Project</h2>
    
    <div style="margin-bottom: 1.5rem; padding: 1rem; background: #fef3c7; border: 1px solid #fde68a; border-radius: 8px;">
        <div style="display: flex; align-items: start; gap: 0.75rem;">
            <i class="bi bi-info-circle" style="color: #d97706; font-size: 1.25rem; margin-top: 2px;"></i>
            <div>
                <div style="font-family: 'Poppins', Arial, sans-serif; font-size: 0.875rem; color: #92400e; font-weight: 500; margin-bottom: 0.25rem;">Editing Project</div>
                <div style="font-family: 'Montserrat', Arial, sans-serif; font-size: 0.8125rem; color: #78350f;">You can only edit projects with pending status. Once a project is active or ongoing, it cannot be modified.</div>
            </div>
        </div>
    </div>

    <div class="project-modal__content">
        <form id="editProjectForm">
            <input type="hidden" id="editProjectId" name="projectId" value="{{ project.id }}">
            
            <div class="form-group">
                <label for="editProjectTitle">Project Title <span class="required">*</span></label>
                <input type="text" id="editProjectTitle" name="title" value="{{ project.title }}" placeholder="e.g., Logo Design for Tech Startup" required>
            </div>
            
            <div class="form-group">
                <label for="editProjectCategory">Category <span class="required">*</span></label>
                <select id="editProjectCategory" name="category" required>
                    <option value="">Select a category</option>
                    {% if categories is defined %}
                        {% for category in categories %}
                            <option value="{{ category.id }}" {% if project.category and project.category.id == category.id %}selected{% endif %}>{{ category.name }}</option>
                        {% endfor %}
                    {% endif %}
                </select>
            </div>
            
            <div class="form-group">
                <label for="editProjectDescription">Description <span class="required">*</span></label>
                <textarea id="editProjectDescription" name="description" rows="6" placeholder="Describe your project requirements, style preferences, timeline, and any specific details..." required>{{ project.description }}</textarea>
            </div>
            
            <div class="form-group">
                <label for="editProjectBudget">Budget Range <span class="required">*</span></label>
                <select id="editProjectBudget" name="budget" required>
                    <option value="">Select budget range</option>
                    <option value="0-500" {% if project.budget >= 0 and project.budget <= 500 %}selected{% endif %}>$0 - $500</option>
                    <option value="500-1000" {% if project.budget > 500 and project.budget <= 1000 %}selected{% endif %}>$500 - $1,000</option>
                    <option value="1000-5000" {% if project.budget > 1000 and project.budget <= 5000 %}selected{% endif %}>$1,000 - $5,000</option>
                    <option value="5000+" {% if project.budget > 5000 %}selected{% endif %}>$5,000+</option>
                </select>
                <small class="form-hint">The backend will convert this range to an average value</small>
            </div>
        </form>
    </div>
    <div class="project-modal__footer">
        <button type="button" class="btn btn-secondary btn-cancel-edit" id="cancelEditProject">
            <span>Cancel</span>
        </button>
        <button type="submit" form="editProjectForm" class="btn btn-primary btn-update-project-modal" id="submitEditProjectBtn" style="display: flex; align-items: center; gap: 0.5rem;">
            <i class="bi bi-check-circle-fill"></i>
            <span>Save Changes</span>
        </button>
    </div>
</div>

