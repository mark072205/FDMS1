{% set statusClass = project.status == 'completed' ? 'status-completed' : (project.status == 'ongoing' ? 'status-active' : (project.status == 'pending' ? 'status-pending' : 'status-cancelled')) %}
<div class="project-modal-content">
    <h2 class="project-modal__title">Project Details</h2>
    
    <div style="display: flex; gap: 1rem; align-items: center; flex-wrap: wrap; margin-bottom: 1.5rem;">
        <span class="status-badge {{ statusClass }}" style="font-family: 'Montserrat', Arial, sans-serif; font-size: 0.875rem; padding: 0.375rem 0.75rem; border-radius: 12px;">{{ project.status|capitalize }}</span>
        <span style="font-family: 'Montserrat', Arial, sans-serif; color: #6b7280; font-size: 0.875rem;">Posted {{ project.createdAt|date('M d, Y') }}</span>
    </div>

    <!-- Project Information -->
    <div style="margin-bottom: 1.5rem;">
        <h3 style="font-family: 'Poppins', Arial, sans-serif; font-size: 1rem; margin: 0 0 0.75rem 0; color: #111827; font-weight: 600;">Title</h3>
        <div style="font-family: 'Poppins', Arial, sans-serif; font-weight: 600; color: #111827; font-size: 1.125rem; margin-bottom: 0.5rem;">{{ project.title }}</div>
    </div>

    <!-- Category -->
    {% if project.category %}
    <div style="margin-bottom: 1.5rem;">
        <h3 style="font-family: 'Poppins', Arial, sans-serif; font-size: 1rem; margin: 0 0 0.75rem 0; color: #111827; font-weight: 600;">Category</h3>
        <div style="font-family: 'Montserrat', Arial, sans-serif; color: #374151; font-size: 0.9375rem;">{{ project.category.name }}</div>
    </div>
    {% endif %}

    <!-- Description -->
    <div style="margin-bottom: 1.5rem;">
        <h3 style="font-family: 'Poppins', Arial, sans-serif; font-size: 1rem; margin: 0 0 0.75rem 0; color: #111827; font-weight: 600;">Description</h3>
        <div style="font-family: 'Montserrat', Arial, sans-serif; color: #374151; line-height: 1.8; white-space: pre-wrap; padding: 1rem; background: #f9fafb; border-radius: 8px;">{{ project.description }}</div>
    </div>

    <!-- Project Details -->
    <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem; margin-bottom: 1.5rem;">
        <div>
            <div style="font-family: 'Poppins', Arial, sans-serif; font-size: 0.75rem; color: #6b7280; margin-bottom: 0.25rem; text-transform: uppercase; letter-spacing: 0.5px;">Budget</div>
            <div style="font-family: 'Montserrat', Arial, sans-serif; font-size: 1.25rem; font-weight: 600; color: #111827;">${{ project.budget|number_format(2, '.', ',') }}</div>
        </div>
        <div>
            <div style="font-family: 'Poppins', Arial, sans-serif; font-size: 0.75rem; color: #6b7280; margin-bottom: 0.25rem; text-transform: uppercase; letter-spacing: 0.5px;">Status</div>
            <div style="font-family: 'Montserrat', Arial, sans-serif; font-size: 0.9375rem; color: #111827;">{{ project.status|capitalize }}</div>
        </div>
        <div>
            <div style="font-family: 'Poppins', Arial, sans-serif; font-size: 0.75rem; color: #6b7280; margin-bottom: 0.25rem; text-transform: uppercase; letter-spacing: 0.5px;">Created</div>
            <div style="font-family: 'Montserrat', Arial, sans-serif; font-size: 0.9375rem; color: #111827;">{{ project.createdAt|date('M d, Y') }}</div>
        </div>
    </div>

    <!-- Proposals Count -->
    {% if project.proposals|length > 0 %}
    <div style="margin-bottom: 1.5rem; padding: 1rem; background: #eff6ff; border: 1px solid #bfdbfe; border-radius: 8px;">
        <div style="font-family: 'Poppins', Arial, sans-serif; font-size: 0.875rem; color: #1e40af; font-weight: 500;">{{ project.proposals|length }} proposal{{ project.proposals|length != 1 ? 's' : '' }} received</div>
    </div>
    {% endif %}

    <!-- Action Button -->
    <div class="project-modal__footer">
        {% if project.status == 'pending' %}
            <button type="button" class="btn btn-primary btn-edit-project-modal" data-project-id="{{ project.id }}" style="display: flex; align-items: center; gap: 0.5rem;">
                <i class="bi bi-pencil-fill"></i>
                <span>Edit Project</span>
            </button>
        {% endif %}
    </div>
</div>

