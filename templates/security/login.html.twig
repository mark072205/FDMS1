{% extends 'base.html.twig' %}

{% block title %}Login - Mark & Motion{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/header.css') }}">
    <link rel="stylesheet" href=" {{ asset('styles/login.css')}} ">
    <link rel="stylesheet" href="{{ asset('styles/footer.css') }}">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
{% endblock %}

{% block body %}
{% include 'security/_headerlogin.html.twig' %}

<div class="login-container">
    <div class="login-box">
        <h1>Log in to Mark & Motion</h1>

        {% if error %}
            <div class="alert alert-danger" style="color: #dc3545; background-color: #f8d7da; border: 1px solid #f5c6cb; padding: 12px; border-radius: 4px; margin-bottom: 20px; font-family: 'Montserrat', Arial, sans-serif; word-wrap: break-word; overflow-wrap: break-word; max-width: 100%; box-sizing: border-box;">
                {{ error.messageKey|trans(error.messageData, 'security') }}
            </div>
        {% endif %}

        <form method="post">
            <div class="input-group-icon">
                <i class="bi bi-person input-icon"></i>
                <input type="text" name="_identifier" placeholder="Email or Username" class="input-field input-with-icon" value="{{ last_username }}" required>
            </div>
            <div class="input-group-icon">
                <div class="password-wrapper">
                    <i class="bi bi-person-lock input-icon"></i>
                    <input type="password" name="_password" id="password" placeholder="Password" class="input-field input-with-icon" required>
                    <button type="button" class="toggle-password" id="togglePassword">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                            <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"></path>
                            <line x1="1" y1="1" x2="23" y2="23"></line>
                        </svg>
                    </button>
                </div>
            </div>
            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
            <button type="submit" class="login-btn">Log In</button>
        </form>

        <div class="oauth-divider">
            <span class="oauth-divider-text">or</span>
        </div>

        <a class="oauth-google-btn" href="{{ path('connect_google_start', { mode: 'login' }) }}">
            <span class="oauth-google-icon" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 48 48" focusable="false">
                    <path fill="#EA4335" d="M24 9.5c3.3 0 6.3 1.2 8.6 3.2l6.4-6.4C35.1 2.8 29.8 0 24 0 14.6 0 6.6 5.4 2.6 13.2l7.5 5.8C12.1 13.2 17.6 9.5 24 9.5z"/>
                    <path fill="#34A853" d="M46.1 24.5c0-1.6-.1-2.8-.4-4.1H24v7.8h12.5c-.5 3-2.4 5.7-5.3 7.4l8.1 6.3c4.7-4.4 7.8-10.8 7.8-17.4z"/>
                    <path fill="#4A90E2" d="M10.1 28.8c-1-3-1-6.2 0-9.2l-7.5-5.8C.4 18.4 0 21.1 0 24s.4 5.6 2.6 10.2l7.5-5.4z"/>
                    <path fill="#FBBC05" d="M24 48c6.5 0 12-2.1 16-5.7l-8.1-6.3c-2.2 1.5-5.1 2.4-7.9 2.4-6.4 0-11.9-3.7-13.9-9.1l-7.5 5.4C6.6 42.6 14.6 48 24 48z"/>
                </svg>
            </span>
            <span class="oauth-google-text">Continue with Google</span>
        </a>

        {% for message in app.flashes('error') %}
            <div class="alert alert-danger" style="color: #dc3545; background-color: #f8d7da; border: 1px solid #f5c6cb; padding: 10px 12px; border-radius: 6px; margin-top: 12px; font-family: 'Montserrat', Arial, sans-serif; font-size: 0.875rem; line-height: 1.35; word-wrap: break-word; overflow-wrap: break-word; max-width: 100%; box-sizing: border-box;">
                {{ message }}
            </div>
        {% endfor %}

        <div class="signup-cta">
            <p class="signup-cta-text">Don't have a Mark & Motion account?</p>
            <a href="/signup" class="signup-outline-btn">Sign Up</a>
        </div>
    </div>
</div>

{% include 'security/_footerlogin.html.twig' %}

{% endblock %}

{% block javascripts %}
    <script src=" {{asset('controllers/login.js')}} "></script>
{% endblock %}
